---
/*
  Section #devis de Cortege : CTA final de conversion. Tone dark
  (--green-900), traitement premium avec un halo dore radial discret en
  fond. Titre H2 gros en Fraunces, sous-titre court, puis un vrai
  formulaire de qualification envoye via Web3Forms (fetch, sans
  rechargement). Etats geres cote client : idle, envoi, succes, erreur.

  Cle Web3Forms editable en une ligne ci-dessous (WEB3FORMS_KEY).
*/
import Eyebrow from './Eyebrow.astro';
import ButtonArrow from './ButtonArrow.astro';

// Cle Web3Forms. A editer ici en une seule ligne pour changer la boite
// de reception des demandes de devis.
const WEB3FORMS_KEY = '4dcb99a0-1a80-4aa2-958f-3785bc0d2bb7';

// Sujet des emails recus, transmis en champ cache.
const SUBJECT = 'Nouvelle demande de devis Transport Événementiel Nantes';

// En-tete de section.
const H2 = 'Décrivez-nous votre événement. On orchestre le transport.';
const SOUS_TITRE =
  'Trajets, véhicules, rotations : un devis clair et un interlocuteur unique pour toute la logistique de déplacement.';

// Options du type d'evenement.
const TYPES = [
  'Mariage',
  'Séminaire ou événement d\'entreprise',
  'Navette de groupe',
  'Autre',
];

// Besoins specifiques (cases a cocher, optionnel).
const BESOINS = [
  'Transferts gare ou aéroport',
  'Navettes de nuit',
  'Plusieurs rotations',
  'Autocar ou grande capacité',
];
---

<section
  id="devis"
  data-tone="dark"
  class="devis relative overflow-hidden bg-green-900 py-section text-on-dark scroll-mt-24"
>
  <!-- Halo dore radial discret, apparait au reveal -->
  <span class="devis-halo" aria-hidden="true" data-reveal></span>

  <!-- Layout deux colonnes : editorial a gauche, formulaire a droite.
       L'id formulaire-devis est pose sur la grille : les CTA deposent le
       visiteur sur l'ensemble titre + formulaire, pas dans un vide. -->
  <div
    id="formulaire-devis"
    class="devis-grille container relative scroll-mt-24"
  >
    <!-- Colonne gauche : editorial, centre verticalement -->
    <div class="devis-intro" data-reveal-stagger="120">
      <div data-reveal>
        <Eyebrow tone="dark">Parlons de votre événement</Eyebrow>
      </div>

      <h2 class="devis-titre mt-6 text-on-dark" data-reveal>{H2}</h2>

      <p class="type-body mt-6 max-w-md text-on-dark/[0.92]" data-reveal>
        {SOUS_TITRE}
      </p>

      <p class="devis-ancrage type-nav mt-6 text-on-dark/[0.85]" data-reveal>
        Nantes et Grand Ouest, adossé à CHL VTC.
      </p>
    </div>

    <!-- Colonne droite : carte formulaire posee sur --green-800 -->
    <div class="devis-form-wrap" data-reveal>
      <!-- Message de succes (masque tant que non soumis) -->
      <div
        id="devis-success"
        class="devis-success"
        role="status"
        aria-live="polite"
        hidden
      >
        <span class="devis-success-mark" aria-hidden="true"></span>
        <p class="devis-success-titre">
          Demande reçue. On revient vers vous très vite avec un premier devis.
        </p>
      </div>

      <!-- Formulaire de qualification -->
      <form id="devis-form" class="devis-form" novalidate>
        <!-- Champs caches Web3Forms -->
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value={SUBJECT} />
        <input type="hidden" name="from_name" value="Site Transport Événementiel Nantes" />
        <!-- Honeypot anti-spam : doit rester vide -->
        <input
          type="checkbox"
          name="botcheck"
          class="devis-honeypot"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <!-- 1. Type d'evenement -->
        <div class="devis-field">
          <label class="devis-label" for="devis-type">
            Type d'événement <span class="devis-req" aria-hidden="true">*</span>
          </label>
          <div class="devis-select-wrap">
            <select id="devis-type" name="Type d'événement" class="devis-input" required>
              <option value="" disabled selected>Choisir...</option>
              {TYPES.map((t) => <option value={t}>{t}</option>)}
            </select>
            <span class="devis-select-arrow" aria-hidden="true"></span>
          </div>
        </div>

        <!-- 2 + 5. Date et nombre de personnes (2 colonnes desktop) -->
        <div class="devis-grid">
          <div class="devis-field">
            <label class="devis-label" for="devis-date">
              Date approximative <span class="devis-req" aria-hidden="true">*</span>
            </label>
            <input id="devis-date" name="Date approximative" type="date" class="devis-input" required />
          </div>
          <div class="devis-field">
            <label class="devis-label" for="devis-pax">
              Nombre de personnes <span class="devis-req" aria-hidden="true">*</span>
            </label>
            <input
              id="devis-pax"
              name="Nombre de personnes"
              type="number"
              min="1"
              inputmode="numeric"
              placeholder="Ex : 40"
              class="devis-input"
              required
            />
          </div>
        </div>

        <!-- 3 + 4. Ville de depart et d'arrivee (2 colonnes desktop) -->
        <div class="devis-grid">
          <div class="devis-field">
            <label class="devis-label" for="devis-depart">
              Ville de départ <span class="devis-req" aria-hidden="true">*</span>
            </label>
            <input id="devis-depart" name="Ville de départ" type="text" placeholder="Ex : Nantes" class="devis-input" required />
          </div>
          <div class="devis-field">
            <label class="devis-label" for="devis-arrivee">
              Ville d'arrivée ou lieu <span class="devis-req" aria-hidden="true">*</span>
            </label>
            <input id="devis-arrivee" name="Ville d'arrivée ou lieu" type="text" placeholder="Ex : Château de..." class="devis-input" required />
          </div>
        </div>

        <!-- 6. Besoins specifiques (optionnel) -->
        <fieldset class="devis-field devis-fieldset">
          <legend class="devis-label">Besoins spécifiques</legend>
          <div class="devis-checks">
            {
              BESOINS.map((b, i) => (
                <label class="devis-check" for={`devis-besoin-${i}`}>
                  <input
                    id={`devis-besoin-${i}`}
                    type="checkbox"
                    name="Besoins spécifiques"
                    value={b}
                    class="devis-check-input"
                  />
                  <span class="devis-check-box" aria-hidden="true"></span>
                  <span class="devis-check-text">{b}</span>
                </label>
              ))
            }
          </div>
        </fieldset>

        <!-- 7 + 9. Nom et telephone (2 colonnes desktop) -->
        <div class="devis-grid">
          <div class="devis-field">
            <label class="devis-label" for="devis-nom">
              Nom <span class="devis-req" aria-hidden="true">*</span>
            </label>
            <input id="devis-nom" name="Nom" type="text" autocomplete="name" placeholder="Votre nom" class="devis-input" required />
          </div>
          <div class="devis-field">
            <label class="devis-label" for="devis-tel">
              Téléphone <span class="devis-req" aria-hidden="true">*</span>
            </label>
            <input id="devis-tel" name="Téléphone" type="tel" autocomplete="tel" placeholder="06 00 00 00 00" class="devis-input" required />
          </div>
        </div>

        <!-- 8. Email -->
        <div class="devis-field">
          <label class="devis-label" for="devis-email">
            Email <span class="devis-req" aria-hidden="true">*</span>
          </label>
          <input id="devis-email" name="Email" type="email" autocomplete="email" placeholder="vous@exemple.fr" class="devis-input" required />
        </div>

        <!-- 10. Message libre (optionnel) -->
        <div class="devis-field">
          <label class="devis-label" for="devis-message">Décrivez votre besoin</label>
          <textarea id="devis-message" name="Message" rows="4" placeholder="Contexte, horaires, contraintes particulières..." class="devis-input devis-textarea"></textarea>
        </div>

        <!-- Message d'erreur (masque par defaut) -->
        <p id="devis-error" class="devis-error" role="alert" aria-live="assertive" hidden></p>

        <!-- Bouton d'envoi -->
        <div class="devis-actions">
          <ButtonArrow variant="solid" type="submit" label="Envoyer ma demande" class="devis-submit" />
          <p class="devis-privacy type-nav">
            Vos informations servent uniquement à établir votre devis.
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('devis-form') as HTMLFormElement | null;
  const success = document.getElementById('devis-success');
  const errorBox = document.getElementById('devis-error');

  if (form && success && errorBox) {
    const submitBtn = form.querySelector<HTMLButtonElement>('.devis-submit');
    const submitLabel = submitBtn?.querySelector<HTMLElement>('.type-button');
    const defaultLabel = submitLabel?.textContent ?? 'Envoyer ma demande';

    const setError = (message: string) => {
      errorBox.textContent = message;
      errorBox.hidden = false;
    };
    const clearError = () => {
      errorBox.textContent = '';
      errorBox.hidden = true;
    };

    const setSending = (sending: boolean) => {
      if (!submitBtn) return;
      submitBtn.disabled = sending;
      submitBtn.setAttribute('aria-busy', String(sending));
      if (submitLabel) {
        submitLabel.textContent = sending ? 'Envoi...' : defaultLabel;
      }
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearError();

      // Validation client des champs requis (contrainte native HTML).
      if (!form.checkValidity()) {
        const firstInvalid = form.querySelector<HTMLElement>(':invalid');
        firstInvalid?.focus();
        setError('Merci de compléter les champs requis avant d\'envoyer.');
        return;
      }

      setSending(true);

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await response.json();

        if (response.ok && data.success) {
          // Succes : le message remplace le formulaire.
          form.hidden = true;
          success.hidden = false;
          requestAnimationFrame(() => success.classList.add('is-shown'));
          success.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          setSending(false);
          setError(
            'L\'envoi a échoué. Merci de réessayer ou de nous contacter directement.'
          );
        }
      } catch {
        setSending(false);
        setError(
          'Problème de connexion. Vérifiez votre réseau puis réessayez.'
        );
      }
    });
  }
</script>

<style>
  /* Halo dore radial discret, centre haut, tres doux. Anime son apparition
     via la primitive reveal (opacite pilotee par [data-reveal]). */
  .devis-halo {
    position: absolute;
    top: -10%;
    left: 50%;
    width: min(70rem, 120%);
    height: 40rem;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse at center,
      rgba(201, 162, 75, 0.16) 0%,
      rgba(201, 162, 75, 0.06) 35%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Grille deux colonnes : editorial (gauche) + formulaire (droite).
     Les deux colonnes sont alignees EN HAUT (align-items: start), en mobile
     comme en desktop. Le titre editorial de gauche demarre a la meme hauteur
     que le premier champ du formulaire a droite : aucun centrage vertical,
     aucun vide en haut de la carte. Chaque colonne prend la hauteur de son
     contenu. */
  .devis-grille {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .devis-grille {
      grid-template-columns: 43fr 57fr;
      gap: 4rem;
      align-items: start;
    }
  }

  /* Colonne editoriale : alignee en haut, a la meme hauteur que le premier
     champ du formulaire. Aucun centrage, aucun padding ni min-height force. */
  .devis-intro {
    align-self: start;
  }

  /* Titre du CTA final : display Fraunces. Taille reduite pour tenir
     proprement en colonne, sans deborder ni ecraser le formulaire. */
  .devis-titre {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  /* Mention d'ancrage local, discrete sous le sous-titre. */
  .devis-ancrage {
    letter-spacing: 0.01em;
  }

  /* Carte formulaire : fond legerement releve, fin liseré, coins doux,
     pour poser visuellement le formulaire face a l'editorial. */
  .devis-form-wrap {
    background-color: var(--green-800);
    border: 1px solid var(--line-on-dark);
    border-radius: 20px;
    padding: 2rem;
  }

  @media (min-width: 640px) {
    .devis-form-wrap {
      padding: 2.5rem;
    }
  }

  /* ---- Formulaire ---- */
  .devis-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-align: left;
  }

  .devis-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  /* Paires courtes : 2 colonnes sur desktop, empilees sur mobile. */
  .devis-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .devis-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .devis-label {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    color: var(--on-dark);
  }

  .devis-req {
    color: var(--gold);
  }

  /* Champs sur --green-900 (plus sombre que la carte --green-800),
     bordure fine, focus liseré doré. Contraste net dans la carte. */
  .devis-input {
    width: 100%;
    background-color: var(--green-900);
    color: var(--on-dark);
    border: 1px solid var(--line-on-dark);
    border-radius: 0.5rem;
    padding: 0.75rem 0.9rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.4;
    transition:
      border-color 300ms var(--ease),
      box-shadow 300ms var(--ease),
      background-color 300ms var(--ease);
  }

  .devis-input::placeholder {
    color: rgba(237, 231, 218, 0.5);
  }

  .devis-input:hover {
    border-color: rgba(237, 231, 218, 0.28);
  }

  .devis-input:focus {
    outline: none;
    background-color: var(--green-700);
    border-color: var(--gold);
    box-shadow: 0 0 0 2px rgba(201, 162, 75, 0.35);
  }

  /* Le champ date affiche son indicateur en clair sur fond sombre. */
  .devis-input[type='date']::-webkit-calendar-picker-indicator {
    filter: invert(0.85) sepia(0.3) saturate(2) hue-rotate(5deg);
    cursor: pointer;
    opacity: 0.7;
  }
  .devis-input[type='date']::-webkit-calendar-picker-indicator:hover {
    opacity: 1;
  }

  .devis-textarea {
    resize: vertical;
    min-height: 6.5rem;
  }

  /* Select : fleche personnalisee, on masque celle du navigateur. */
  .devis-select-wrap {
    position: relative;
  }
  .devis-select-wrap select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 2.5rem;
    cursor: pointer;
  }
  .devis-select-arrow {
    position: absolute;
    right: 1rem;
    top: 50%;
    width: 0.55rem;
    height: 0.55rem;
    border-right: 1.5px solid rgba(237, 231, 218, 0.6);
    border-bottom: 1.5px solid rgba(237, 231, 218, 0.6);
    transform: translateY(-70%) rotate(45deg);
    pointer-events: none;
  }
  .devis-input option {
    background-color: var(--green-900);
    color: var(--on-dark);
  }

  /* Fieldset besoins : sans bordure native, on garde le rythme. */
  .devis-fieldset {
    border: 0;
    margin: 0;
    padding: 0;
  }
  .devis-fieldset legend {
    padding: 0;
  }

  .devis-checks {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
    margin-top: 0.25rem;
  }
  @media (min-width: 640px) {
    .devis-checks {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Case a cocher stylee, accessible (input reel masque visuellement). */
  .devis-check {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(237, 231, 218, 0.92);
    user-select: none;
  }
  .devis-check-input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }
  .devis-check-box {
    flex-shrink: 0;
    width: 1.15rem;
    height: 1.15rem;
    border: 1px solid var(--line-on-dark);
    border-radius: 0.3rem;
    background-color: var(--green-900);
    position: relative;
    transition:
      border-color 200ms var(--ease),
      background-color 200ms var(--ease);
  }
  .devis-check-box::after {
    content: '';
    position: absolute;
    left: 0.36rem;
    top: 0.16rem;
    width: 0.3rem;
    height: 0.55rem;
    border-right: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    transform: rotate(45deg) scale(0);
    transition: transform 200ms var(--ease);
  }
  .devis-check-input:checked + .devis-check-box {
    background-color: var(--gold);
    border-color: var(--gold);
  }
  .devis-check-input:checked + .devis-check-box::after {
    transform: rotate(45deg) scale(1);
  }
  .devis-check-input:focus-visible + .devis-check-box {
    outline: none;
    box-shadow: 0 0 0 2px rgba(201, 162, 75, 0.5);
  }

  /* Honeypot : invisible aux humains, piege a bots. */
  .devis-honeypot {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    overflow: hidden;
  }

  /* Zone d'action : bouton + mention de confidentialite. */
  .devis-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }
  .devis-privacy {
    color: rgba(237, 231, 218, 0.92);
  }

  .devis-submit[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Message d'erreur : discret, liseré rouge sobre coherent avec la palette. */
  .devis-error {
    margin: 0;
    padding: 0.75rem 0.9rem;
    border-radius: 0.5rem;
    background-color: rgba(180, 70, 60, 0.15);
    border: 1px solid rgba(216, 120, 100, 0.4);
    color: #f0c9c1;
    font-family: var(--font-body);
    font-size: 0.95rem;
  }

  /* ---- Message de succes ---- */
  /* Tant que l'attribut hidden est present (etat par defaut), le bloc est
     retire du flux : sinon son display:flex l'emporte sur [hidden] et il
     occupe le haut de la carte, poussant le formulaire vers le bas. */
  .devis-success[hidden] {
    display: none;
  }
  .devis-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    padding: 2.5rem 1.5rem;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 700ms var(--ease),
      transform 700ms var(--ease);
  }
  .devis-success.is-shown {
    opacity: 1;
    transform: translateY(0);
  }
  .devis-success-mark {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    border: 1px solid var(--gold);
    position: relative;
    flex-shrink: 0;
  }
  .devis-success-mark::after {
    content: '';
    position: absolute;
    left: 1.15rem;
    top: 0.85rem;
    width: 0.7rem;
    height: 1.25rem;
    border-right: 2px solid var(--gold);
    border-bottom: 2px solid var(--gold);
    transform: rotate(45deg);
  }
  .devis-success-titre {
    margin: 0;
    max-width: 32rem;
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--on-dark);
  }
</style>
