---
/*
  Section #cas-client de Cortege : PARCOURS DE GROUPE EN SCROLL FIXE.

  Principe. La section se fixe a l'ecran (sticky) a l'arrivee. Le scroll
  n'avance plus la page : il fait progresser un convoi de groupe le long d'un
  trace dore multi-brins (plusieurs vehicules ensemble). A chaque etape
  atteinte, le temoignage correspondant apparait en grande typographie
  editoriale (Clash Display), un seul visible a la fois, en fondu doux. Apres
  la derniere etape, la page reprend son defilement normal.

  Technique. Un conteneur haut (500vh) contient un bloc sticky de 100vh. La
  progression du scroll DANS le conteneur (getBoundingClientRect, synchronise
  avec Lenis via requestAnimationFrame) pilote quelle etape est active. Aucun
  blocage brutal du scroll : le visiteur garde le controle.

  SEO / GEO. TOUS les temoignages sont presents en HTML au chargement (texte
  reel, jamais injecte en JS), en <blockquote>/<cite>. Si le JS echoue ou est
  desactive, la version empilee (fallback) reste lisible : le sticky et les
  fondus ne sont actives qu'apres la classe .is-enhanced posee par le JS.

  Accessibilite. prefers-reduced-motion : pas de sticky ni d'animation, les 5
  etapes sont empilees et lisibles. Contraste AA : creme sur vert profond via
  color: var(--on-dark) + opacity (jamais l'opacite arbitraire Tailwind qui
  retombe sur un gris delave sur variable non-RGB).

  Mobile. Pas de sticky (trop lourd) : ligne verticale a gauche, 5 etapes
  empilees (volume, citation en grand, attribution), reveal en fondu a
  l'entree dans le viewport, defilement naturel.

  L'ancre #cas-client est conservee : la navigation (Header, Footer, Hero)
  pointe "Realisations" vers cette section.

  Carte 1 (Titouan N.) = temoignage reel, 5 etoiles. Etapes 2 a 5 = exemples
  representatifs (voir la table ETAPES).
*/
import Eyebrow from './Eyebrow.astro';
import ButtonArrow from './ButtonArrow.astro';

// =====================================================================
// LES 5 ETAPES DU PARCOURS DE GROUPE.
// Chaque etape porte un compteur de volume (ancre l'echelle du groupe)
// et un temoignage. Le temoignage 1 (Titouan N.) est un VRAI avis,
// affiche tel quel avec 5 etoiles. Les temoignages 2 a 5 sont des
// exemples representatifs credibles, a remplacer par de vrais verbatims
// des qu'ils seront disponibles.
// =====================================================================
const ETAPES = [
  {
    etape: 'Arrivée des invités',
    volume: '49 invités transportés',
    vehicule: 'van',
    vedette: true,
    type: 'Mariage',
    accroche: 'Ponctualité parfaite, une équipe fiable et facile à joindre.',
    auteur: 'Titouan N.',
    role: 'Mariage, Loire-Atlantique',
    detail:
      'Simon a assuré le transport de nos invités le jour de notre mariage avec un grand professionnalisme. Très à l\'écoute, transparent et réactif, il a pris le temps d\'optimiser les trajets pour trouver le meilleur compromis entre le confort des invités et le budget. Tout s\'est déroulé parfaitement : ponctualité, excellente communication et super organisation. Nous recommandons à 100 pour cent.',
  },
  {
    etape: 'Navettes inter-sites',
    volume: '2 jours de rotations',
    vehicule: 'autocar',
    vedette: false,
    type: 'Séminaire d\'entreprise',
    accroche: 'Une navette séminaire d\'entreprise coordonnée sans le moindre retard sur deux jours.',
    auteur: 'Camille R.',
    role: 'Séminaire, secteur tertiaire',
    detail:
      'Pour notre séminaire d\'entreprise à Nantes, nous avions besoin de navettes entre l\'hôtel, le lieu de réunion et un restaurant. Le transport des participants a été entièrement coordonné par un seul interlocuteur, avec les transferts gare et les rotations. Aucun trajet à gérer de notre côté.',
  },
  {
    etape: 'Transfert dirigeants',
    volume: 'Flotte de berlines coordonnée',
    vehicule: 'van',
    vedette: false,
    type: 'Transfert corporate',
    accroche: 'Un transfert de dirigeants à Nantes avec une flotte de berlines cadrée à la minute.',
    auteur: 'Julien M.',
    role: 'Transfert dirigeants, Nantes',
    detail:
      'Nous cherchions un transport de dirigeants fiable entre la gare de Nantes, le siège et un dîner d\'affaires. Véhicules impeccables, chauffeurs ponctuels, coordination sans faille. Le niveau attendu pour un transfert corporate en Loire-Atlantique.',
  },
  {
    etape: 'Grand rassemblement',
    volume: 'Plusieurs centaines de personnes',
    vehicule: 'autocar',
    vedette: false,
    type: 'Navette de groupe',
    accroche: 'Une navette de groupe de plusieurs centaines de personnes, orchestrée par une seule équipe.',
    auteur: 'Sophie L.',
    role: 'Rassemblement, Grand Ouest',
    detail:
      'Pour notre rassemblement dans le Grand Ouest, il fallait un transport de groupe de grande capacité depuis plusieurs points. Berlines, vans et autocars dimensionnés selon le volume, rotations enchaînées sans attente. Une navette événementielle clé en main.',
  },
  {
    etape: 'Retours de nuit',
    volume: 'Rotations jusqu\'à la fin de soirée',
    vehicule: 'autocar',
    vedette: false,
    type: 'Mariage',
    accroche: 'Des navettes de mariage et retours de nuit gérés sans qu\'on y pense.',
    auteur: 'Marie et Thomas D.',
    role: 'Mariage, Vendée',
    detail:
      'Pour notre mariage en Vendée, le transport des invités et les navettes de nuit étaient notre inquiétude. Tout a été orchestré : transferts, rotations, retours de fin de soirée en sécurité. Un transport de mariage dans le Grand Ouest géré de bout en bout.',
  },
];

const CTA_PHRASE = 'Votre événement mérite la même tranquillité.';

// Trois brins paralleles legerement decales : suggerent plusieurs
// vehicules qui avancent ensemble (un groupe, pas un trajet isole).
// Coordonnees dans le repere du viewBox 0 0 120 460, vertical.
const BRINS = [
  'M 60 20 C 40 130, 80 230, 56 330 S 44 420, 60 448',
  'M 52 20 C 32 130, 72 230, 48 330 S 36 420, 52 448',
  'M 68 20 C 48 130, 88 230, 64 330 S 52 420, 68 448',
];
---

<section
  id="cas-client"
  data-tone="dark"
  class="temoignages relative bg-green-900 text-on-dark"
  data-temoignages
>
  <!-- ============================================================
       CONTENEUR HAUT (500vh) : sa hauteur cree la course de scroll.
       Le bloc interieur est sticky (100vh) et reste fixe pendant que
       la progression avance le convoi et bascule les temoignages.
       Le fallback (JS off / reduced-motion) rend ce conteneur en flux
       normal : les 5 etapes s'empilent et restent lisibles.
       ============================================================ -->
  <div class="temoignages-piste" data-piste>
    <div class="temoignages-sticky">
      <div class="container temoignages-grille">
        <!-- ---------- Colonne parcours (gauche) : trace + jalons ---------- -->
        <div class="temoignages-parcours" aria-hidden="true">
          <div class="temoignages-parcours-tete">
            <Eyebrow tone="dark">Ils nous ont fait confiance</Eyebrow>
          </div>

          <div class="temoignages-plan">
            <svg
              class="temoignages-svg"
              viewBox="0 0 120 460"
              fill="none"
              preserveAspectRatio="xMidYMid meet"
              data-plan
            >
              <!-- Trois brins paralleles dores : plusieurs vehicules
                   ensemble. Traces progressivement selon la progression. -->
              <g stroke="var(--gold)" stroke-linecap="round" fill="none">
                {
                  BRINS.map((d, i) => (
                    <path
                      class="temoignages-brin"
                      d={d}
                      style={`--i:${i}`}
                      stroke-width={i === 0 ? 1.6 : 1}
                      opacity={i === 0 ? 0.6 : 0.28}
                    />
                  ))
                }
              </g>

              <!-- Jalons d'etape : un anneau + point par etape, allume
                   quand la progression l'atteint. Positions le long du
                   rail (echelonnees verticalement). -->
              {
                ETAPES.map((_, i) => {
                  const y = 40 + (i * 384) / (ETAPES.length - 1);
                  return (
                    <g
                      class="temoignages-jalon"
                      data-jalon
                      data-index={i}
                      transform={`translate(60 ${y})`}
                    >
                      <circle class="temoignages-jalon-halo" r="11" fill="var(--gold)" opacity="0" />
                      <circle
                        class="temoignages-jalon-anneau"
                        r="6.5"
                        fill="var(--green-900)"
                        stroke="var(--gold)"
                        stroke-width="1.4"
                      />
                      <circle class="temoignages-jalon-point" r="2.4" fill="var(--gold-soft)" />
                    </g>
                  );
                })
              }

              <!-- Convoi : deux vehicules (van + autocar) qui avancent
                   ensemble le long du rail selon la progression (pilote
                   par offsetDistance en JS). Silhouettes minimalistes. -->
              <g class="temoignages-vehicule temoignages-vehicule--van" data-vehicule="0" aria-hidden="true">
                <rect x="-7" y="-4" width="14" height="8" rx="2" fill="var(--gold-soft)" />
                <rect x="-4.5" y="-2.4" width="4.5" height="3" rx="0.8" fill="var(--green-900)" opacity="0.65" />
              </g>
              <g class="temoignages-vehicule temoignages-vehicule--autocar" data-vehicule="1" aria-hidden="true">
                <rect x="-10" y="-3.4" width="20" height="6.8" rx="2" fill="var(--gold)" />
                <rect x="-7.5" y="-1.8" width="13" height="2.4" rx="0.6" fill="var(--green-900)" opacity="0.6" />
              </g>
            </svg>

            <!-- Indicateur de progression discret : 5 points, l'actif
                 plus lumineux. Reflete l'etape courante. -->
            <ol class="temoignages-dots" data-dots aria-hidden="true">
              {ETAPES.map((_, i) => <li class="temoignages-dot" data-dot data-index={i} />)}
            </ol>
          </div>
        </div>

        <!-- ---------- Colonne temoignages (droite) : le contenu reel ---------- -->
        <div class="temoignages-scene">
          <ol class="temoignages-liste" data-liste>
            {
              ETAPES.map((t, i) => (
                <li
                  class:list={['temoignage', { 'is-vedette': t.vedette }]}
                  data-temoignage
                  data-index={i}
                >
                  <div class="temoignage-etape">
                    <span class="temoignage-volume type-eyebrow text-gold">
                      {t.volume}
                    </span>
                    <span class="temoignage-etape-nom">{t.etape}</span>
                  </div>

                  {t.vedette && (
                    <span class="temoignage-etoiles" aria-label="Cinq étoiles sur cinq">
                      <span aria-hidden="true">★★★★★</span>
                    </span>
                  )}

                  <span class="temoignage-guillemet text-gold" aria-hidden="true">
                    &ldquo;
                  </span>

                  <blockquote class="temoignage-citation">
                    <p class="temoignage-accroche">{t.accroche}</p>
                    <p class="temoignage-detail">{t.detail}</p>
                    <footer class="temoignage-attribution">
                      <cite class="temoignage-auteur">{t.auteur}</cite>
                      <span class="temoignage-role type-nav">{t.role}</span>
                    </footer>
                  </blockquote>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- CTA de fin de section, centre -->
    <div class="temoignages-cta" data-reveal>
      <p class="type-body temoignages-cta-phrase">{CTA_PHRASE}</p>
      <ButtonArrow variant="solid" href="#formulaire-devis" label="Demander un devis" />
    </div>
  </div>
</section>

<style>
  /* ============================================================
     PARCOURS DE GROUPE EN SCROLL FIXE.
     Deux etats :
       - PAR DEFAUT (fallback, JS off / reduced-motion) : conteneur en
         flux normal, 5 etapes empilees, toutes visibles et lisibles.
       - AMELIORE (.is-enhanced pose par le JS) : conteneur haut + bloc
         sticky, un temoignage visible a la fois, fondus pilotes par la
         progression du scroll.
     ============================================================ */

  .temoignages {
    scroll-margin-top: 6rem;
  }

  /* -- Conteneur de piste. Par defaut : hauteur auto (fallback empile). -- */
  .temoignages-piste {
    position: relative;
  }

  .temoignages-sticky {
    padding-top: clamp(4rem, 8vw, 7rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }

  /* Grille : parcours (gauche, etroit) + scene temoignages (droite, large).
     Asymetrique et aeree. Fallback : les deux colonnes empilees. */
  .temoignages-grille {
    display: grid;
    gap: clamp(2rem, 5vw, 4.5rem);
  }

  /* ---- Colonne parcours ---- */
  .temoignages-parcours-tete {
    margin-bottom: 1.75rem;
  }

  .temoignages-plan {
    position: relative;
  }

  .temoignages-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* Brins : traces progressivement. dash-array/offset poses en JS a partir
     de getTotalLength ; la progression globale pilote l'offset. */
  .temoignages-brin {
    transition: stroke-dashoffset 120ms linear;
  }

  /* Jalons : eteints au repos, s'allument quand la progression les atteint. */
  .temoignages-jalon-anneau,
  .temoignages-jalon-point {
    transition:
      fill 400ms var(--ease),
      stroke 400ms var(--ease);
  }
  .temoignages-jalon.is-active .temoignages-jalon-point {
    fill: var(--gold);
  }
  .temoignages-jalon.is-active .temoignages-jalon-halo {
    animation: temoignages-pulse 900ms var(--ease) both;
  }

  /* Vehicules du convoi : masques tant que le JS n'a pas pris la main
     (fallback : inutiles). Reveles en mode ameliore. */
  .temoignages-vehicule {
    opacity: 0;
    transition: opacity 500ms var(--ease);
  }

  /* Indicateur a points : discret, l'actif plus lumineux et plus grand. */
  .temoignages-dots {
    display: none;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }
  .temoignages-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--gold);
    opacity: 0.28;
    transition:
      opacity 350ms var(--ease),
      transform 350ms var(--ease);
  }
  .temoignages-dot.is-active {
    opacity: 1;
    transform: scale(1.35);
  }

  /* ---- Colonne scene / temoignages ---- */

  /* Etiquette d'etape : volume dore (echelle du groupe) + nom d'etape. */
  .temoignage-etape {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1.25rem;
  }
  .temoignage-etape-nom {
    font-family: var(--font-body);
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    color: var(--on-dark);
    opacity: 0.7;
  }

  .temoignage-etoiles {
    display: block;
    font-size: 1.05rem;
    letter-spacing: 0.15em;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  /* Grand guillemet dore, accent editorial. */
  .temoignage-guillemet {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    line-height: 0.4;
    height: clamp(1.5rem, 3vw, 2.4rem);
    opacity: 0.85;
  }

  .temoignage-citation {
    margin: 1.25rem 0 0;
  }

  /* Accroche : la phrase forte, en tres grande typographie Clash Display,
     sans carte ni cadre. Style magazine. Creme AA sur vert profond. */
  .temoignage-accroche {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 500;
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    line-height: 1.16;
    letter-spacing: -0.015em;
    color: var(--on-dark);
    text-wrap: pretty;
    margin: 0;
  }

  /* Detail complet : texte courant plus petit, discret mais lisible (AA). */
  .temoignage-detail {
    margin: 1.5rem 0 0;
    max-width: 46ch;
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--on-dark);
    opacity: 0.86;
  }

  .temoignage-attribution {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .temoignage-auteur {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 600;
    font-size: 1rem;
    color: var(--on-dark);
  }
  .temoignage-role {
    color: var(--on-dark);
    opacity: 0.7;
  }

  /* ---- CTA de fin ---- */
  .temoignages-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-bottom: clamp(4rem, 8vw, 7rem);
    margin-top: clamp(2rem, 5vw, 3.5rem);
  }
  .temoignages-cta-phrase {
    max-width: 28rem;
    margin-bottom: 1.5rem;
    color: var(--on-dark);
    opacity: 0.92;
  }

  @keyframes temoignages-pulse {
    0% {
      opacity: 0.5;
      transform: scale(0.5);
    }
    100% {
      opacity: 0;
      transform: scale(2.1);
    }
  }

  /* ============================================================
     FALLBACK EMPILE (etat par defaut, avant .is-enhanced).
     Les 5 etapes sont visibles, empilees, separees. Ligne verticale
     de parcours a gauche. Aucune dependance JS pour la lisibilite.
     ============================================================ */
  .temoignage {
    position: relative;
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--line-on-dark);
  }
  .temoignage:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }
  .temoignages-liste {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ============================================================
     MODE AMELIORE : pilote par .is-enhanced (pose par le JS une fois
     l'amelioration active). Sticky + un temoignage a la fois + fondus.
     ============================================================ */
  .temoignages.is-enhanced .temoignages-piste {
    /* Course de scroll : 5 etapes -> ~500vh. */
    height: 500vh;
  }
  .temoignages.is-enhanced .temoignages-sticky {
    position: sticky;
    top: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }
  .temoignages.is-enhanced .temoignages-dots {
    display: flex;
  }
  .temoignages.is-enhanced .temoignages-vehicule {
    opacity: 0.95;
  }

  /* En mode ameliore, la scene devient une pile empilee (grid stack) :
     tous les temoignages superposes, un seul opaque a la fois. */
  .temoignages.is-enhanced .temoignages-liste {
    display: grid;
    min-height: 60vh;
    align-items: center;
  }
  .temoignages.is-enhanced .temoignage {
    grid-area: 1 / 1;
    padding-bottom: 0;
    margin-bottom: 0;
    border-bottom: none;
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 600ms var(--ease),
      transform 600ms var(--ease);
    pointer-events: none;
  }
  .temoignages.is-enhanced .temoignage.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* ============================================================
     DESKTOP (>= 1024px) : grille asymetrique parcours | scene.
     Uniquement en mode ameliore ; le fallback reste empile.
     ============================================================ */
  @media (min-width: 1024px) {
    .temoignages.is-enhanced .temoignages-grille {
      grid-template-columns: minmax(220px, 0.9fr) 1.6fr;
      align-items: center;
    }
    .temoignages.is-enhanced .temoignages-svg {
      max-height: 62vh;
    }
  }

  /* Sous le point de bascule desktop, le parcours SVG reste discret :
     en fallback empile on masque le grand SVG (une simple ligne verticale
     via bordure suffit) pour ne pas alourdir. En mode ameliore mobile, on
     conserve la ligne verticale a gauche geree ci-dessous. */
  @media (max-width: 1023px) {
    .temoignages-parcours {
      display: none;
    }
    /* Ligne verticale de parcours a gauche de chaque etape (mobile). */
    .temoignages-scene {
      position: relative;
      padding-left: 1.75rem;
    }
    .temoignages-scene::before {
      content: '';
      position: absolute;
      left: 3px;
      top: 0.5rem;
      bottom: 0.5rem;
      width: 1.5px;
      background: linear-gradient(
        to bottom,
        transparent,
        var(--gold) 8%,
        var(--gold) 92%,
        transparent
      );
      opacity: 0.5;
    }
    .temoignage::before {
      content: '';
      position: absolute;
      left: -1.75rem;
      top: 0.4rem;
      width: 9px;
      height: 9px;
      margin-left: -0.5px;
      border-radius: 50%;
      background-color: var(--gold);
      box-shadow: 0 0 0 4px var(--green-900);
    }
  }

  /* ============================================================
     REDUCED MOTION : jamais de sticky ni d'animation. Meme si le JS
     ajoutait .is-enhanced, on neutralise tout ici : les etapes restent
     empilees, toutes visibles, aucune transition.
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .temoignages.is-enhanced .temoignages-piste {
      height: auto;
    }
    .temoignages.is-enhanced .temoignages-sticky {
      position: static;
      min-height: 0;
      display: block;
    }
    .temoignages.is-enhanced .temoignages-liste {
      display: block;
      min-height: 0;
    }
    .temoignages.is-enhanced .temoignage {
      grid-area: auto;
      opacity: 1;
      transform: none;
      transition: none;
      pointer-events: auto;
      padding-bottom: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: clamp(2.5rem, 5vw, 4rem);
      border-bottom: 1px solid var(--line-on-dark);
    }
    .temoignages.is-enhanced .temoignage:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }
    .temoignages-brin,
    .temoignages-jalon-anneau,
    .temoignages-jalon-point,
    .temoignages-dot,
    .temoignages-vehicule {
      transition: none;
    }
  }
</style>

<script>
  /* ============================================================
     Parcours de groupe : progression du scroll -> etape active.

     - On n'active le mode sticky/fondu (.is-enhanced) que si le viewport
       est assez large ET que l'utilisateur n'a pas demande reduced-motion.
       Sinon on laisse le fallback empile (deja lisible en HTML).
     - La progression = position de la piste dans la fenetre
       (getBoundingClientRect), lue dans une boucle rAF (synchro Lenis, qui
       pilote le scroll natif). On en deduit l'index d'etape actif, on trace
       les brins (stroke-dashoffset), on avance les vehicules le long du rail
       (offsetDistance) et on met a jour jalons + dots.
     - Tous les textes sont deja dans le DOM : ce script ne fait qu'orchestrer
       l'affichage, jamais l'injection de contenu (SEO/GEO).
     ============================================================ */

  function initTemoignages() {
    const section = document.querySelector<HTMLElement>('[data-temoignages]');
    if (!section) return;

    const piste = section.querySelector<HTMLElement>('[data-piste]');
    const items = Array.from(
      section.querySelectorAll<HTMLElement>('[data-temoignage]')
    );
    const jalons = Array.from(
      section.querySelectorAll<SVGGElement>('[data-jalon]')
    );
    const dots = Array.from(section.querySelectorAll<HTMLElement>('[data-dot]'));
    const brins = Array.from(
      section.querySelectorAll<SVGPathElement>('.temoignages-brin')
    );
    const vehicules = Array.from(
      section.querySelectorAll<SVGGElement>('[data-vehicule]')
    );
    const rail = brins[0] ?? null;

    if (!piste || items.length === 0) return;

    const total = items.length;
    const reduce = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    // Longueur du rail pour placer les vehicules (offsetDistance en %).
    let railLen = 0;
    if (rail) {
      try {
        railLen = rail.getTotalLength();
      } catch {
        railLen = 0;
      }
    }

    // Prepare le trace des brins (dash-array = longueur, offset plein = cache).
    const brinLens = brins.map((b) => {
      let len = 0;
      try {
        len = b.getTotalLength();
      } catch {
        len = 0;
      }
      b.style.strokeDasharray = String(len);
      b.style.strokeDashoffset = String(len);
      return len;
    });

    // Applique une progression p (0..1) : trace, vehicules, etape active.
    let activeIndex = -1;
    const apply = (p: number) => {
      const clamped = Math.min(Math.max(p, 0), 1);

      // Trace des brins proportionnel a la progression.
      brins.forEach((b, i) => {
        b.style.strokeDashoffset = String(brinLens[i] * (1 - clamped));
      });

      // Vehicules le long du rail (le second legerement en retrait pour
      // suggerer un convoi, jamais devant la tete).
      if (railLen > 0 && rail) {
        vehicules.forEach((v, i) => {
          const retrait = i === 0 ? 0 : 0.06;
          const dist = Math.min(Math.max(clamped - retrait, 0), 1) * railLen;
          const pt = rail.getPointAtLength(dist);
          v.setAttribute('transform', `translate(${pt.x} ${pt.y})`);
        });
      }

      // Etape active : segmente [0..1] en `total` paliers.
      const index = Math.min(Math.floor(clamped * total), total - 1);
      if (index !== activeIndex) {
        activeIndex = index;
        items.forEach((el, i) => el.classList.toggle('is-active', i === index));
        jalons.forEach((el, i) =>
          el.classList.toggle('is-active', i <= index)
        );
        dots.forEach((el, i) => el.classList.toggle('is-active', i === index));
      }
    };

    // Mode ameliore : uniquement desktop large et hors reduced-motion.
    const mqEnhance = window.matchMedia(
      '(min-width: 1024px) and (prefers-reduced-motion: no-preference)'
    );

    let rafId = 0;
    let running = false;

    const measure = () => {
      const rect = piste.getBoundingClientRect();
      const vh = window.innerHeight;
      // Course utile = hauteur de piste - une fenetre (duree du sticky).
      const course = rect.height - vh;
      if (course <= 0) {
        apply(0);
        return;
      }
      // p = combien on a defile dans la piste (0 en haut, 1 en bas).
      const p = (-rect.top) / course;
      apply(p);
    };

    const loop = () => {
      measure();
      rafId = window.requestAnimationFrame(loop);
    };

    const enable = () => {
      if (running) return;
      running = true;
      section.classList.add('is-enhanced');
      // Reveal vehicules deja gere par CSS (.is-enhanced). Demarre la boucle.
      measure();
      rafId = window.requestAnimationFrame(loop);
    };

    const disable = () => {
      if (!running) return;
      running = false;
      section.classList.remove('is-enhanced');
      window.cancelAnimationFrame(rafId);
      // Fallback empile : tout visible, on retire les etats actifs.
      items.forEach((el) => el.classList.remove('is-active'));
      jalons.forEach((el) => el.classList.remove('is-active'));
      dots.forEach((el) => el.classList.remove('is-active'));
    };

    const sync = () => {
      if (reduce) {
        disable();
        return;
      }
      if (mqEnhance.matches) enable();
      else disable();
    };

    sync();
    // Rebranche a chaque changement de largeur / preference.
    if (mqEnhance.addEventListener) {
      mqEnhance.addEventListener('change', sync);
    } else if ((mqEnhance as any).addListener) {
      (mqEnhance as any).addListener(sync);
    }
    window.addEventListener('resize', () => {
      // Recalcule les longueurs de rail/brins au redimensionnement.
      if (rail) {
        try {
          railLen = rail.getTotalLength();
        } catch {
          railLen = 0;
        }
      }
      brins.forEach((b, i) => {
        try {
          brinLens[i] = b.getTotalLength();
        } catch {
          brinLens[i] = brinLens[i];
        }
      });
    });
  }

  if (document.readyState !== 'loading') {
    initTemoignages();
  } else {
    document.addEventListener('DOMContentLoaded', initTemoignages, {
      once: true,
    });
  }
  document.addEventListener('astro:page-load', initTemoignages);
</script>
