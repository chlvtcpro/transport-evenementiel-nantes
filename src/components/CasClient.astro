---
/*
  Section #cas-client de Cortege : PARCOURS DE GROUPE HORIZONTAL, SCROLL FIXE.

  Mise en page (desktop, mode ameliore). La section se fixe (100vh) et se
  divise en deux zones horizontales :
    - Zone haute (~65%) : LE TEMOIGNAGE, centre, largeur de lecture 900px.
      Volume dore en capitales, nom d'etape, grand guillemet, citation en
      tres grande typo (Clash Display), detail, puis nom + contexte. Un seul
      temoignage a la fois, fondu doux.
    - Zone basse (~35%) : LE PARCOURS horizontal pleine largeur. Une ligne a
      trois brins paralleles (convoi) qui traverse l'ecran de 10% a 90%,
      passant PAR les cinq points d'etape. La portion parcourue se remplit en
      dore ; trois silhouettes de vehicules (van + autocars) avancent le long
      de la ligne selon la progression. Sous chaque point : nom d'etape en
      capitales + volume (visible pour l'etape active).

  Technique. Un conteneur haut (500vh) contient un bloc sticky de 100vh. La
  progression du scroll DANS le conteneur (getBoundingClientRect, boucle rAF
  synchronisee avec Lenis qui pilote le scroll natif) pilote l'etape active,
  le remplissage de la ligne et la position du convoi. Aucun blocage brutal.

  SEO / GEO. TOUS les temoignages sont presents en HTML au chargement (texte
  reel, jamais injecte en JS), en <blockquote>/<cite>. Si le JS echoue ou est
  desactive, la version empilee (fallback) reste lisible : sticky et fondus ne
  sont actives qu'apres la classe .is-enhanced posee par le JS.

  Accessibilite. prefers-reduced-motion : pas de sticky ni d'animation, les 5
  etapes empilees et lisibles. Contraste AA : creme sur vert profond via
  color: var(--on-dark) + opacity (jamais l'opacite arbitraire Tailwind qui
  retombe sur un gris delave sur variable non-RGB).

  Mobile. Pas de sticky : ligne verticale a gauche traversant tous les points,
  5 etapes empilees, reveal en fondu a l'entree dans le viewport.

  L'ancre #cas-client est conservee : la navigation (Header, Footer, Hero)
  pointe "Realisations" vers cette section.

  Etape 1 (Titouan N.) = temoignage reel, 5 etoiles. Etapes 2 a 5 = exemples
  representatifs (voir la table ETAPES).
*/
import Eyebrow from './Eyebrow.astro';
import ButtonArrow from './ButtonArrow.astro';

// =====================================================================
// LES 5 ETAPES DU PARCOURS DE GROUPE.
// Chaque etape porte un compteur de volume (ancre l'echelle du groupe)
// et un temoignage. L'etape 1 (Titouan N.) est un VRAI avis, affiche tel
// quel avec 5 etoiles. Les etapes 2 a 5 sont des exemples representatifs
// credibles, a remplacer par de vrais verbatims des qu'ils seront
// disponibles.
// =====================================================================
const ETAPES = [
  {
    etape: 'Arrivée des invités',
    volume: '49 invités transportés',
    vedette: true,
    type: 'Mariage',
    accroche: 'Ponctualité parfaite, une équipe fiable et facile à joindre.',
    auteur: 'Titouan N.',
    role: 'Mariage, Loire-Atlantique',
    detail:
      'Simon a assuré le transport de nos invités le jour de notre mariage avec un grand professionnalisme. Très à l\'écoute, transparent et réactif, il a pris le temps d\'optimiser les trajets pour trouver le meilleur compromis entre le confort des invités et le budget. Tout s\'est déroulé parfaitement : ponctualité, excellente communication et super organisation. Nous recommandons à 100 pour cent.',
  },
  {
    etape: 'Navettes inter-sites',
    volume: '2 jours de rotations',
    vedette: false,
    type: 'Séminaire d\'entreprise',
    accroche: 'Une navette séminaire d\'entreprise coordonnée sans le moindre retard sur deux jours.',
    auteur: 'Camille R.',
    role: 'Séminaire, secteur tertiaire',
    detail:
      'Pour notre séminaire d\'entreprise à Nantes, nous avions besoin de navettes entre l\'hôtel, le lieu de réunion et un restaurant. Le transport des participants a été entièrement coordonné par un seul interlocuteur, avec les transferts gare et les rotations. Aucun trajet à gérer de notre côté.',
  },
  {
    etape: 'Transfert dirigeants',
    volume: 'Flotte de berlines coordonnée',
    vedette: false,
    type: 'Transfert corporate',
    accroche: 'Un transfert de dirigeants à Nantes avec une flotte de berlines cadrée à la minute.',
    auteur: 'Julien M.',
    role: 'Transfert dirigeants, Nantes',
    detail:
      'Nous cherchions un transport de dirigeants fiable entre la gare de Nantes, le siège et un dîner d\'affaires. Véhicules impeccables, chauffeurs ponctuels, coordination sans faille. Le niveau attendu pour un transfert corporate en Loire-Atlantique.',
  },
  {
    etape: 'Grand rassemblement',
    volume: 'Plusieurs centaines de personnes',
    vedette: false,
    type: 'Navette de groupe',
    accroche: 'Une navette de groupe de plusieurs centaines de personnes, orchestrée par une seule équipe.',
    auteur: 'Sophie L.',
    role: 'Rassemblement, Grand Ouest',
    detail:
      'Pour notre rassemblement dans le Grand Ouest, il fallait un transport de groupe de grande capacité depuis plusieurs points. Berlines, vans et autocars dimensionnés selon le volume, rotations enchaînées sans attente. Une navette événementielle clé en main.',
  },
  {
    etape: 'Retours de nuit',
    volume: 'Rotations jusqu\'à la fin de soirée',
    vedette: false,
    type: 'Mariage',
    accroche: 'Des navettes de mariage et retours de nuit gérés sans qu\'on y pense.',
    auteur: 'Marie et Thomas D.',
    role: 'Mariage, Vendée',
    detail:
      'Pour notre mariage en Vendée, le transport des invités et les navettes de nuit étaient notre inquiétude. Tout a été orchestré : transferts, rotations, retours de fin de soirée en sécurité. Un transport de mariage dans le Grand Ouest géré de bout en bout.',
  },
];

const CTA_PHRASE = 'Votre événement mérite la même tranquillité.';

// -- Geometrie du parcours horizontal (repere viewBox 0 0 1000 120) --
// La ligne va de X0 a X1 ; le brin central (rail) sert d'axe aux points
// et aux vehicules. Trois brins paralleles decales verticalement de ~4px
// (en unites viewBox), avec une legere ondulation douce identique.
const VB_W = 1000;
const VB_H = 120;
const RAIL_Y = 46; // milieu vertical de la zone parcours (viewBox)
const X0 = 100; // 10% de la largeur
const X1 = 900; // 90% de la largeur
const N = ETAPES.length;
// X de chaque etape, reparti regulierement de X0 a X1.
const stepX = ETAPES.map((_, i) => X0 + ((X1 - X0) * i) / (N - 1));
// Position verticale du rail exprimee en pourcentage de la hauteur SVG.
// Les points et les vehicules sont des elements HTML positionnes en absolu
// par-dessus le SVG (via left/top en %), pour rester de vrais cercles/icones
// non deformes par le preserveAspectRatio="none" qui etire le trace en X.
const railTopPct = (RAIL_Y / VB_H) * 100;
// Fraction verticale du trace au niveau de chaque point (ondulation) : les
// brins passent tous par RAIL_Y au niveau des points de controle X0/mid/X1,
// mais entre deux, l'ondulation ecarte de +/- l'amplitude. Aux positions
// d'etape reparties regulierement, on approxime la hauteur reelle du rail.

// Construit un brin ondulant doux entre X0 et X1 a une hauteur de base y.
// Ondulation faible (amplitude ~9 unites) via deux courbes cubiques ; les
// trois brins partagent la meme forme, seul y change (parallelisme).
function brin(y: number): string {
  const a = 9; // amplitude d'ondulation
  const midL = X0 + (X1 - X0) * 0.33;
  const midR = X0 + (X1 - X0) * 0.66;
  return [
    `M ${X0} ${y}`,
    `C ${X0 + 90} ${y - a}, ${midL - 60} ${y - a}, ${midL} ${y}`,
    `S ${midR - 60} ${y + a}, ${midR} ${y}`,
    `S ${X1 - 90} ${y - a}, ${X1} ${y}`,
  ].join(' ');
}
const BRIN_OFFSETS = [-4, 0, 4]; // decalage vertical des 3 brins
const BRINS = BRIN_OFFSETS.map((dy) => brin(RAIL_Y + dy));
const RAIL = brin(RAIL_Y); // brin central : rail des points et vehicules
---

<section
  id="cas-client"
  data-tone="dark"
  class="temoignages relative bg-green-900 text-on-dark"
  data-temoignages
>
  <!-- ============================================================
       CONTENEUR HAUT (500vh) : sa hauteur cree la course de scroll.
       Le bloc interieur est sticky (100vh). Fallback (JS off /
       reduced-motion) : flux normal, 5 etapes empilees, lisibles.
       ============================================================ -->
  <div class="temoignages-piste" data-piste>
    <div class="temoignages-sticky">
      <!-- Eyebrow fixe en haut a gauche pendant toute la section. -->
      <div class="temoignages-eyebrow container">
        <Eyebrow tone="dark">Ils nous ont fait confiance</Eyebrow>
      </div>

      <!-- ---------- ZONE HAUTE : le temoignage (centre, 900px) ---------- -->
      <div class="temoignages-scene">
        <!-- Parcours VERTICAL (mobile uniquement, < 1024px). Overlay a gauche
             de la liste : deux brins paralleles tres rapproches (convoi), un
             brin de remplissage dont la hauteur suit le scroll, cinq points
             d'etape alignes par le JS sur le centre de chaque temoignage, et
             une silhouette de vehicule qui descend le long de la ligne au fil
             du scroll. Masque en desktop (le parcours horizontal prend le
             relais). aria-hidden : purement decoratif, le texte reste lu. -->
        <div class="temoignages-rail-vertical" data-rail-vertical aria-hidden="true">
          <div class="rv-brins">
            <span class="rv-brin"></span>
            <span class="rv-brin"></span>
            <span class="rv-brin rv-brin-fill" data-rv-fill></span>
          </div>
          {
            ETAPES.map((_, i) => (
              <span class="rv-jalon" data-rv-jalon data-index={i} />
            ))
          }
          <span class="rv-vehicule" data-rv-vehicule>
            <svg width="26" height="15" viewBox="0 0 36 16" fill="none" aria-hidden="true">
              <rect x="1" y="2" width="32" height="12" rx="3" fill="var(--gold)" />
              <rect x="4" y="4.5" width="6" height="4.5" rx="1" fill="var(--green-900)" opacity="0.75" />
              <rect x="11.5" y="4.5" width="6" height="4.5" rx="1" fill="var(--green-900)" opacity="0.75" />
              <rect x="19" y="4.5" width="6" height="4.5" rx="1" fill="var(--green-900)" opacity="0.75" />
              <rect x="26.5" y="4.5" width="4" height="4.5" rx="1" fill="var(--green-900)" opacity="0.75" />
              <circle cx="9" cy="15" r="1.7" fill="var(--gold-soft)" />
              <circle cx="25" cy="15" r="1.7" fill="var(--gold-soft)" />
            </svg>
          </span>
        </div>

        <ol class="temoignages-liste" data-liste>
          {
            ETAPES.map((t, i) => (
              <li
                class:list={['temoignage', { 'is-vedette': t.vedette }]}
                data-temoignage
                data-index={i}
              >
                <div class="temoignage-etape">
                  <span class="temoignage-volume type-eyebrow text-gold">
                    {t.volume}
                  </span>
                  <span class="temoignage-etape-nom">{t.etape}</span>
                </div>

                {t.vedette && (
                  <span class="temoignage-etoiles" aria-label="Cinq étoiles sur cinq">
                    <span aria-hidden="true">★★★★★</span>
                  </span>
                )}

                <span class="temoignage-guillemet text-gold" aria-hidden="true">
                  &ldquo;
                </span>

                <blockquote class="temoignage-citation">
                  <p class="temoignage-accroche">{t.accroche}</p>
                  <p class="temoignage-detail">{t.detail}</p>
                  <footer class="temoignage-attribution">
                    <cite class="temoignage-auteur">{t.auteur}</cite>
                    <span class="temoignage-role type-nav">{t.role}</span>
                  </footer>
                </blockquote>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- ---------- ZONE BASSE : le parcours horizontal (pleine largeur) ---------- -->
      <div class="temoignages-parcours" aria-hidden="true">
        <!-- La scene du parcours : le SVG (le trace seul) sous une couche HTML
             (points + vehicules) positionnee en absolu. Le SVG s'etire en X
             (preserveAspectRatio=none) pour occuper toute la largeur ; les
             points et vehicules restent de vraies formes non deformees car ce
             sont des elements HTML places en pourcentage par-dessus. -->
        <div class="temoignages-scene-parcours" data-scene-parcours>
          <svg
            class="temoignages-svg"
            viewBox="0 0 1000 120"
            fill="none"
            preserveAspectRatio="none"
            data-plan
          >
            <!-- Trois brins paralleles dores (base, opacite 0.35) : le convoi. -->
            <g stroke="var(--gold)" stroke-linecap="round" fill="none">
              {
                BRINS.map((d) => (
                  <path
                    class="temoignages-brin"
                    d={d}
                    stroke-width="1.5"
                    opacity="0.35"
                    vector-effect="non-scaling-stroke"
                  />
                ))
              }
            </g>

            <!-- Portion parcourue : le rail redessine par-dessus, dore plein,
                 revele de gauche a droite via stroke-dashoffset (progression). -->
            <path
              class="temoignages-rail-fill"
              d={RAIL}
              stroke="var(--gold)"
              stroke-width="2"
              stroke-linecap="round"
              fill="none"
              opacity="0.9"
              vector-effect="non-scaling-stroke"
              data-rail-fill
            />
          </svg>

          <!-- Cinq points d'etape : elements HTML (vrais cercles) poses en
               absolu sur le rail, a left = position X en %, top = rail en %. -->
          {
            ETAPES.map((_, i) => (
              <span
                class="temoignages-jalon"
                data-jalon
                data-index={i}
                style={`left:${(stepX[i] / VB_W) * 100}%; top:${railTopPct}%`}
              />
            ))
          }

          <!-- Convoi : trois silhouettes (2 autocars + 1 van), positionnees en
               absolu par le JS le long du rail (left/top en %). Icones inline a
               taille fixe : jamais deformees. -->
          {
            [0, 1, 2].map((i) => (
              <span class="temoignages-vehicule" data-vehicule={i} style={`left:${(X0 / VB_W) * 100}%; top:${railTopPct}%`}>
                {i === 1 ? (
                  <svg class="temoignages-vehicule-icone" width="30" height="16" viewBox="0 0 30 16" fill="none" aria-hidden="true">
                    <rect x="1" y="3" width="26" height="11" rx="2.5" fill="var(--gold)" />
                    <rect x="3.5" y="5.2" width="8" height="4.2" rx="1" fill="var(--green-900)" opacity="0.75" />
                    <rect x="13" y="5.2" width="7" height="4.2" rx="1" fill="var(--green-900)" opacity="0.75" />
                    <circle cx="7.5" cy="15" r="1.6" fill="var(--gold-soft)" />
                    <circle cx="20.5" cy="15" r="1.6" fill="var(--gold-soft)" />
                  </svg>
                ) : (
                  <svg class="temoignages-vehicule-icone" width="36" height="16" viewBox="0 0 36 16" fill="none" aria-hidden="true">
                    <rect x="1" y="2" width="32" height="12" rx="3" fill="var(--gold)" />
                    <rect x="4" y="4.5" width="6" height="4.5" rx="1" fill="var(--green-900)" opacity="0.75" />
                    <rect x="11.5" y="4.5" width="6" height="4.5" rx="1" fill="var(--green-900)" opacity="0.75" />
                    <rect x="19" y="4.5" width="6" height="4.5" rx="1" fill="var(--green-900)" opacity="0.75" />
                    <rect x="26.5" y="4.5" width="4" height="4.5" rx="1" fill="var(--green-900)" opacity="0.75" />
                    <circle cx="9" cy="15" r="1.7" fill="var(--gold-soft)" />
                    <circle cx="25" cy="15" r="1.7" fill="var(--gold-soft)" />
                  </svg>
                )}
              </span>
            ))
          }
        </div>

        <!-- Libelles sous chaque point : nom d'etape + volume (actif).
             Positionnes en pourcentage pour coller aux points du SVG. -->
        <div class="temoignages-labels">
          {
            ETAPES.map((t, i) => (
              <div
                class="temoignages-label"
                data-label
                data-index={i}
                style={`left:${(stepX[i] / VB_W) * 100}%`}
              >
                <span class="temoignages-label-nom">{t.etape}</span>
                <span class="temoignages-label-volume">{t.volume}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- CTA de fin de section, centre -->
    <div class="temoignages-cta" data-reveal>
      <p class="type-body temoignages-cta-phrase">{CTA_PHRASE}</p>
      <ButtonArrow variant="solid" href="#formulaire-devis" label="Demander un devis" />
    </div>
  </div>
</section>

<style>
  /* ============================================================
     PARCOURS DE GROUPE HORIZONTAL, SCROLL FIXE.
     Deux etats :
       - PAR DEFAUT (fallback, JS off / reduced-motion) : flux normal,
         5 etapes empilees, toutes visibles et lisibles.
       - AMELIORE (.is-enhanced pose par le JS) : sticky 100vh, zone haute
         temoignage (fondus) + zone basse parcours horizontal anime.
     ============================================================ */

  .temoignages {
    scroll-margin-top: 6rem;
  }

  .temoignages-piste {
    position: relative;
  }

  /* -- Bloc sticky : en fallback, simple conteneur avec padding. -- */
  .temoignages-sticky {
    padding-top: clamp(4rem, 8vw, 7rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }

  /* Eyebrow : dans le flux en fallback ; fixe en haut en mode ameliore. */
  .temoignages-eyebrow {
    margin-bottom: 2rem;
  }

  /* ---- Zone temoignage (scene) ---- */
  .temoignages-liste {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Etiquette d'etape au-dessus de la citation. */
  .temoignage-etape {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1.1rem;
  }
  .temoignage-etape-nom {
    font-family: var(--font-body);
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    color: var(--on-dark);
    opacity: 0.7;
  }

  .temoignage-etoiles {
    display: block;
    font-size: 1.05rem;
    letter-spacing: 0.15em;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.6rem;
  }

  /* Grand guillemet dore, accent editorial. */
  .temoignage-guillemet {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 0.4;
    height: clamp(1.3rem, 2.5vw, 2rem);
    opacity: 0.85;
  }

  .temoignage-citation {
    margin: 1rem 0 0;
  }

  /* Accroche : la phrase forte, tres grande typo Clash Display, sans cadre. */
  .temoignage-accroche {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 500;
    font-size: clamp(1.5rem, 2.8vw, 2.4rem);
    line-height: 1.16;
    letter-spacing: -0.015em;
    color: var(--on-dark);
    text-wrap: pretty;
    margin: 0;
  }

  /* Detail complet : texte courant plus petit, discret mais lisible (AA). */
  .temoignage-detail {
    margin: 1.35rem 0 0;
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--on-dark);
    opacity: 0.86;
  }

  .temoignage-attribution {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .temoignage-auteur {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 600;
    font-size: 1rem;
    color: var(--on-dark);
  }
  .temoignage-role {
    color: var(--on-dark);
    opacity: 0.7;
  }

  /* ---- Zone parcours ---- */
  .temoignages-parcours {
    position: relative;
  }
  /* Scene : conteneur relatif qui empile le SVG (trace) et la couche HTML
     (points + vehicules) positionnee en absolu par-dessus. */
  .temoignages-scene-parcours {
    position: relative;
    width: 100%;
    height: 120px;
  }
  .temoignages-svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  /* Portion parcourue : masquee au depart (offset plein), revelee par le JS. */
  .temoignages-rail-fill {
    transition: stroke-dashoffset 120ms linear;
  }

  /* Jalons : vrais cercles HTML poses en absolu sur le rail (centres via
     translate). Anneau dore fin au repos ; se remplissent quand atteints,
     grossissent et pulsent quand actifs. Non deformes (element HTML). */
  .temoignages-jalon {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid var(--gold);
    background: transparent;
    transform: translate(-50%, -50%);
    opacity: 0.5;
    transition:
      opacity 400ms var(--ease),
      width 400ms var(--ease),
      height 400ms var(--ease),
      background-color 400ms var(--ease),
      box-shadow 400ms var(--ease);
  }
  /* Etape franchie : point plein a 0.7. */
  .temoignages-jalon.is-passed {
    background: var(--gold);
    opacity: 0.7;
  }
  /* Etape active : gros point plein + halo diffus pulse. */
  .temoignages-jalon.is-active {
    width: 22px;
    height: 22px;
    background: var(--gold);
    opacity: 1;
    box-shadow: 0 0 0 0 rgba(201, 162, 75, 0.45);
    animation: temoignages-halo 1900ms var(--ease) infinite;
  }

  /* Vehicules : conteneur positionne en absolu (left/top pilotes par le JS le
     long du rail). L'icone interne garde une taille fixe : jamais deformee. */
  .temoignages-vehicule {
    position: absolute;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 500ms var(--ease);
    pointer-events: none;
    line-height: 0;
  }
  .temoignages-vehicule-icone {
    display: block;
  }

  /* Libelles sous les points. Centres sur la position du point (left en %). */
  .temoignages-labels {
    position: relative;
    height: 3.25rem;
    margin-top: 0.35rem;
  }
  .temoignages-label {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    width: max-content;
    max-width: 8.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    pointer-events: none;
  }
  .temoignages-label-nom {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.25;
    color: var(--on-dark);
    opacity: 0.6;
    transition:
      opacity 350ms var(--ease),
      color 350ms var(--ease);
  }
  .temoignages-label.is-active .temoignages-label-nom {
    opacity: 1;
  }
  .temoignages-label-volume {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--gold);
    line-height: 1.2;
    opacity: 0;
    transition: opacity 350ms var(--ease);
  }
  .temoignages-label.is-active .temoignages-label-volume {
    opacity: 1;
  }

  /* ---- CTA de fin ---- */
  .temoignages-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-bottom: clamp(4rem, 8vw, 7rem);
    margin-top: clamp(2rem, 5vw, 3.5rem);
  }
  .temoignages-cta-phrase {
    max-width: 28rem;
    margin-bottom: 1.5rem;
    color: var(--on-dark);
    opacity: 0.92;
  }

  /* Halo pulse de l'etape active : box-shadow dore qui se diffuse et s'estompe.
     transform reserve au centrage (translate -50%,-50%), donc on anime le
     box-shadow (pas le transform) pour ne pas casser le positionnement. */
  @keyframes temoignages-halo {
    0% {
      box-shadow: 0 0 0 0 rgba(201, 162, 75, 0.45);
    }
    70% {
      box-shadow: 0 0 0 18px rgba(201, 162, 75, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(201, 162, 75, 0);
    }
  }

  /* ============================================================
     FALLBACK EMPILE (etat par defaut, avant .is-enhanced).
     Les 5 etapes visibles, empilees, separees. Le parcours horizontal
     (SVG) est masque : la ligne verticale a gauche (geree en mobile
     ci-dessous) sert de fil conducteur. Aucune dependance JS.
     ============================================================ */
  .temoignage {
    position: relative;
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--line-on-dark);
  }
  .temoignage:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }
  /* En fallback, le parcours horizontal n'a pas de sens (pas de scroll
     pilote) : on le masque. La scene garde son fil vertical (mobile). */
  .temoignages:not(.is-enhanced) .temoignages-parcours {
    display: none;
  }

  /* ============================================================
     MODE AMELIORE : sticky 100vh, zones haute/basse, un temoignage
     a la fois. Pilote par .is-enhanced (pose par le JS).
     ============================================================ */
  .temoignages.is-enhanced .temoignages-piste {
    height: 500vh;
  }
  .temoignages.is-enhanced .temoignages-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    padding: 0;
    display: grid;
    /* eyebrow (auto) | temoignage (~65%) | parcours (~35%) */
    grid-template-rows: auto 1fr auto;
  }
  /* Padding-top genereux : le bloc sticky demarre a top:0, sous le header
     fixe (~80px). On degage l'eyebrow pour qu'il ne chevauche jamais le logo. */
  .temoignages.is-enhanced .temoignages-eyebrow {
    margin: 0;
    padding-top: clamp(6rem, 12vh, 8.5rem);
  }

  /* Zone haute : temoignage centre, largeur de lecture 900px. Pile empilee
     (grid stack) : tous superposes, un seul opaque a la fois. */
  .temoignages.is-enhanced .temoignages-scene {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
    overflow: hidden;
  }
  .temoignages.is-enhanced .temoignages-liste {
    display: grid;
    width: 100%;
    max-width: 900px;
    padding: 0 1.5rem;
    align-items: center;
  }
  .temoignages.is-enhanced .temoignage {
    grid-area: 1 / 1;
    padding: 0;
    margin: 0;
    border-bottom: none;
    text-align: center;
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 600ms var(--ease),
      transform 600ms var(--ease);
    pointer-events: none;
  }
  .temoignages.is-enhanced .temoignage.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  /* Centre les blocs internes du temoignage en mode ameliore. */
  .temoignages.is-enhanced .temoignage-etape,
  .temoignages.is-enhanced .temoignage-attribution {
    align-items: center;
  }
  .temoignages.is-enhanced .temoignage-detail {
    max-width: 62ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* Zone basse : parcours pleine largeur, colle en bas de l'ecran. */
  .temoignages.is-enhanced .temoignages-parcours {
    display: block;
    width: 100%;
    padding-bottom: clamp(2rem, 4vh, 3.5rem);
  }
  .temoignages.is-enhanced .temoignages-vehicule {
    opacity: 0.95;
  }

  /* ============================================================
     PARCOURS VERTICAL MOBILE (< 1024px), SCROLL-DRIVEN.
     Overlay .temoignages-rail-vertical pose a gauche de la liste : deux
     brins de base tres rapproches (convoi) + un brin de remplissage dont
     la hauteur suit le scroll, cinq jalons alignes par le JS sur le centre
     de chaque temoignage, une silhouette de vehicule qui descend. Scroll
     naturel (jamais sticky). Masque en desktop.
     Sur desktop (>= 1024px) l'overlay est masque : le parcours horizontal
     prend le relais.
     ============================================================ */
  .temoignages-rail-vertical {
    display: none;
  }

  @media (max-width: 1023px) {
    /* La scene devient le repere du rail vertical : on degage une gouttiere
       a gauche pour la ligne + les jalons, le texte reste a droite. */
    .temoignages-scene {
      position: relative;
      padding-left: 2.25rem;
    }

    /* Overlay du rail : colonne fine calee dans la gouttiere gauche,
       hauteur = toute la liste. Purement decoratif (aria-hidden). */
    .temoignages-rail-vertical {
      display: block;
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 2.25rem;
      pointer-events: none;
      z-index: 1;
    }

    /* Les brins : conteneur vertical centre dans la gouttiere. */
    .rv-brins {
      position: absolute;
      left: 9px;
      top: 0.25rem;
      bottom: 0.25rem;
      width: 8px;
    }
    /* Chaque brin de base : trait vertical fin, dore a 0.35. Les deux brins
       de base sont decales lateralement de ~2.5px l'un de l'autre pour
       evoquer un convoi (deux voies) plutot qu'un trait unique. */
    .rv-brin {
      position: absolute;
      top: 0;
      bottom: 0;
      width: 1.5px;
      border-radius: 1px;
      background: var(--gold);
      opacity: 0.35;
    }
    .rv-brin:nth-child(1) {
      left: 0;
    }
    .rv-brin:nth-child(2) {
      left: 2.5px;
    }
    /* Brin de remplissage : superpose au premier brin, dore plein a 0.9,
       hauteur pilotee par le JS (--rv-progress, 0 a 100%) depuis le haut. */
    .rv-brin-fill {
      left: 1.25px;
      top: 0;
      bottom: auto;
      height: var(--rv-progress, 0%);
      width: 1.5px;
      opacity: 0.9;
      transition: height 120ms linear;
    }

    /* Jalons : vrais cercles poses SUR la ligne, top pilote par le JS
       (--rv-top, centre de chaque temoignage). Anneau dore au repos ;
       plein + halo quand l'etape est atteinte/active. */
    .rv-jalon {
      position: absolute;
      left: 10px;
      top: var(--rv-top, 0px);
      width: 11px;
      height: 11px;
      margin-left: -4px;
      border-radius: 50%;
      border: 1.5px solid var(--gold);
      background: var(--green-900);
      transform: translateY(-50%);
      opacity: 0.5;
      transition:
        opacity 400ms var(--ease),
        background-color 400ms var(--ease),
        box-shadow 400ms var(--ease);
    }
    .rv-jalon.is-passed {
      background: var(--gold);
      opacity: 0.75;
    }
    .rv-jalon.is-active {
      background: var(--gold);
      opacity: 1;
      box-shadow: 0 0 0 0 rgba(201, 162, 75, 0.45);
      animation: temoignages-halo 1900ms var(--ease) infinite;
    }

    /* Vehicule : silhouette doree qui descend le long de la ligne. top
       pilote par le JS (--rv-vehicule-top) selon la progression du scroll. */
    .rv-vehicule {
      position: absolute;
      left: 10px;
      top: var(--rv-vehicule-top, 0px);
      transform: translate(-50%, -50%);
      line-height: 0;
      opacity: 0;
      transition: opacity 500ms var(--ease);
    }
    .rv-vehicule.is-visible {
      opacity: 0.95;
    }
    .rv-vehicule svg {
      display: block;
    }

    /* Chaque temoignage : dans le flux vertical, fondu doux a l'entree dans
       le viewport (classe is-inview posee par le JS). */
    .temoignage {
      position: relative;
      padding-bottom: clamp(2.5rem, 6vw, 3.5rem);
      margin-bottom: clamp(2.5rem, 6vw, 3.5rem);
      border-bottom: 1px solid var(--line-on-dark);
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 650ms var(--ease),
        transform 650ms var(--ease);
    }
    .temoignage:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }
    .temoignage.is-inview {
      opacity: 1;
      transform: translateY(0);
    }
    /* Citation adaptee au mobile : lisible, ni ecrasee ni geante. */
    .temoignage-accroche {
      font-size: clamp(1.35rem, 5.6vw, 1.8rem);
      line-height: 1.2;
    }

    /* Sur mobile on n'active jamais le mode horizontal (gere aussi en JS). */
    .temoignages.is-enhanced .temoignages-piste {
      height: auto;
    }
    .temoignages.is-enhanced .temoignages-sticky {
      position: static;
      height: auto;
      display: block;
      padding-top: clamp(4rem, 8vw, 7rem);
      padding-bottom: clamp(4rem, 8vw, 7rem);
    }
    .temoignages.is-enhanced .temoignages-liste {
      display: block;
      max-width: none;
      padding: 0;
    }
    .temoignages.is-enhanced .temoignage {
      grid-area: auto;
      text-align: left;
      pointer-events: auto;
      padding-bottom: clamp(2.5rem, 6vw, 3.5rem);
      margin-bottom: clamp(2.5rem, 6vw, 3.5rem);
      border-bottom: 1px solid var(--line-on-dark);
    }
    .temoignages.is-enhanced .temoignage:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }
    .temoignages.is-enhanced .temoignage-etape,
    .temoignages.is-enhanced .temoignage-attribution {
      align-items: flex-start;
    }
    .temoignages.is-enhanced .temoignages-parcours {
      display: none;
    }
  }

  /* ============================================================
     REDUCED MOTION : jamais de sticky ni d'animation. Etapes empilees.
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .temoignages.is-enhanced .temoignages-piste {
      height: auto;
    }
    .temoignages.is-enhanced .temoignages-sticky {
      position: static;
      height: auto;
      display: block;
      padding-top: clamp(4rem, 8vw, 7rem);
      padding-bottom: clamp(4rem, 8vw, 7rem);
    }
    .temoignages.is-enhanced .temoignages-liste {
      display: block;
      max-width: none;
      padding: 0;
    }
    .temoignages.is-enhanced .temoignage {
      grid-area: auto;
      text-align: left;
      opacity: 1;
      transform: none;
      transition: none;
      pointer-events: auto;
      padding-bottom: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: clamp(2.5rem, 5vw, 4rem);
      border-bottom: 1px solid var(--line-on-dark);
    }
    .temoignages.is-enhanced .temoignage:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }
    .temoignages.is-enhanced .temoignage-etape,
    .temoignages.is-enhanced .temoignage-attribution {
      align-items: flex-start;
    }
    .temoignages.is-enhanced .temoignages-parcours {
      display: none;
    }
    .temoignages-brin,
    .temoignages-rail-fill,
    .temoignages-jalon,
    .temoignages-vehicule,
    .temoignages-label-nom,
    .temoignages-label-volume {
      transition: none;
    }
    .temoignages-jalon.is-active {
      animation: none;
    }
    /* Mobile scroll-driven : sans mouvement, les temoignages restent
       visibles (pas de fondu a piloter) et le halo du vehicule/jalon est
       fige. */
    .temoignage {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .rv-brin-fill,
    .rv-jalon,
    .rv-vehicule {
      transition: none;
    }
    .rv-jalon.is-active {
      animation: none;
    }
  }

  /* Securite sans JS : si le script mobile ne tourne pas, l'attribut
     data-rv-ready n'est jamais pose ; on garde les temoignages visibles
     (pas de dependance JS pour lire le texte). Une fois le JS pret, il pose
     data-rv-ready sur la section et prend la main sur les fondus. */
  @media (max-width: 1023px) {
    .temoignages:not([data-rv-ready]) .temoignage {
      opacity: 1;
      transform: none;
    }
    /* Sans JS, l'overlay decoratif reste affiche mais le remplissage et le
       vehicule sont sur leur etat initial (0%) : la ligne de base a 0.35
       suffit comme fil conducteur. */
  }
</style>

<script>
  /* ============================================================
     Parcours de groupe HORIZONTAL : progression du scroll -> etape,
     remplissage de la ligne, position du convoi.

     - Mode ameliore (.is-enhanced) uniquement desktop large (>= 1024px)
       et hors reduced-motion ; sinon fallback empile (deja en HTML).
     - Progression = position de la piste (getBoundingClientRect) lue dans
       une boucle rAF (synchro Lenis, qui pilote le scroll natif).
     - On en deduit : l'etape active (fondu du temoignage), le remplissage
       du rail (stroke-dashoffset), la position des 3 vehicules le long du
       rail (getPointAtLength) avec oscillation verticale, l'etat des points
       et des libelles.
     - Tous les textes sont deja dans le DOM : ce script orchestre
       seulement l'affichage, jamais l'injection de contenu (SEO/GEO).
     ============================================================ */

  function initTemoignages() {
    const section = document.querySelector<HTMLElement>('[data-temoignages]');
    if (!section) return;

    const piste = section.querySelector<HTMLElement>('[data-piste]');
    const items = Array.from(
      section.querySelectorAll<HTMLElement>('[data-temoignage]')
    );
    const jalons = Array.from(
      section.querySelectorAll<HTMLElement>('[data-jalon]')
    );
    const labels = Array.from(
      section.querySelectorAll<HTMLElement>('[data-label]')
    );
    const railFill = section.querySelector<SVGPathElement>('[data-rail-fill]');
    const vehicules = Array.from(
      section.querySelectorAll<HTMLElement>('[data-vehicule]')
    );

    // Elements du parcours VERTICAL mobile.
    const scene = section.querySelector<HTMLElement>('.temoignages-scene');
    const railVertical = section.querySelector<HTMLElement>(
      '[data-rail-vertical]'
    );
    const rvFill = section.querySelector<HTMLElement>('[data-rv-fill]');
    const rvJalons = Array.from(
      section.querySelectorAll<HTMLElement>('[data-rv-jalon]')
    );
    const rvVehicule = section.querySelector<HTMLElement>('[data-rv-vehicule]');

    if (!piste || items.length === 0) return;

    const total = items.length;
    const reduce = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    // Longueur du rail (pour placer les vehicules et remplir la ligne).
    let railLen = 0;
    const measureRail = () => {
      if (!railFill) return;
      try {
        railLen = railFill.getTotalLength();
      } catch {
        railLen = 0;
      }
      // Prepare le remplissage : dash = longueur, offset plein = cache.
      railFill.style.strokeDasharray = String(railLen);
      railFill.style.strokeDashoffset = String(railLen);
    };
    measureRail();

    // Applique une progression p (0..1).
    let activeIndex = -1;
    const apply = (p: number) => {
      const clamped = Math.min(Math.max(p, 0), 1);

      // Remplissage du rail de gauche a droite.
      if (railFill && railLen > 0) {
        railFill.style.strokeDashoffset = String(railLen * (1 - clamped));
      }

      // Convoi : 3 vehicules HTML decales le long du rail, oscillation
      // verticale. getPointAtLength renvoie des coordonnees en unites viewBox
      // (x 0..1000, y 0..120) : on les convertit en pourcentage pour piloter
      // left/top des spans absolus (VB_W=1000, VB_H=120).
      if (railFill && railLen > 0) {
        vehicules.forEach((v, i) => {
          const retrait = i * 0.05; // decalage du convoi
          const t = Math.min(Math.max(clamped - retrait, 0), 1);
          const dist = t * railLen;
          const pt = railFill.getPointAtLength(dist);
          const wobble = Math.sin(clamped * Math.PI * 6 + i) * 1.6;
          v.style.left = `${(pt.x / 1000) * 100}%`;
          v.style.top = `${((pt.y + wobble) / 120) * 100}%`;
        });
      }

      // Etape active : segmente [0..1] en `total` paliers.
      const index = Math.min(Math.floor(clamped * total), total - 1);
      if (index !== activeIndex) {
        activeIndex = index;
        items.forEach((el, i) => el.classList.toggle('is-active', i === index));
        labels.forEach((el, i) =>
          el.classList.toggle('is-active', i === index)
        );
        jalons.forEach((el, i) => {
          el.classList.toggle('is-active', i === index);
          el.classList.toggle('is-passed', i < index);
        });
      }
    };

    // Mode ameliore : desktop large hors reduced-motion.
    const mqEnhance = window.matchMedia(
      '(min-width: 1024px) and (prefers-reduced-motion: no-preference)'
    );

    let rafId = 0;
    let running = false;

    const measure = () => {
      const rect = piste.getBoundingClientRect();
      const course = rect.height - window.innerHeight;
      if (course <= 0) {
        apply(0);
        return;
      }
      apply(-rect.top / course);
    };

    const loop = () => {
      measure();
      rafId = window.requestAnimationFrame(loop);
    };

    const enable = () => {
      if (running) return;
      running = true;
      section.classList.add('is-enhanced');
      measureRail();
      measure();
      rafId = window.requestAnimationFrame(loop);
    };

    const disable = () => {
      if (!running) return;
      running = false;
      section.classList.remove('is-enhanced');
      window.cancelAnimationFrame(rafId);
      items.forEach((el) => el.classList.remove('is-active'));
      labels.forEach((el) => el.classList.remove('is-active'));
      jalons.forEach((el) => {
        el.classList.remove('is-active');
        el.classList.remove('is-passed');
      });
    };

    // =====================================================================
    // PARCOURS VERTICAL MOBILE (< 1024px), SCROLL-DRIVEN.
    // Le vehicule descend le long de la ligne au fil du scroll, le brin de
    // remplissage grandit de haut en bas, les jalons s'allument quand le
    // vehicule les depasse, et chaque temoignage apparait en fondu quand il
    // entre dans le viewport. Scroll naturel : aucune position sticky, aucun
    // blocage. Tous les textes sont deja dans le DOM.
    // =====================================================================
    const mqMobile = window.matchMedia(
      '(max-width: 1023px) and (prefers-reduced-motion: no-preference)'
    );
    let mobileOn = false;
    let mobileRaf = 0;
    // Centres verticaux (px, relatifs a .temoignages-scene) de chaque jalon,
    // cales sur le centre du bloc etape de chaque temoignage.
    let jalonCenters: number[] = [];

    // Mesure la position verticale de chaque point (centre du repere d'etape
    // du temoignage) et positionne les jalons dessus. Recalcule au resize.
    const measureMobile = () => {
      if (!scene) return;
      const sceneTop = scene.getBoundingClientRect().top;
      jalonCenters = items.map((el) => {
        const anchor =
          el.querySelector<HTMLElement>('.temoignage-etape') ?? el;
        const r = anchor.getBoundingClientRect();
        // Centre vertical de l'ancre, relatif au haut de la scene.
        return r.top - sceneTop + r.height / 2;
      });
      rvJalons.forEach((j, i) => {
        if (jalonCenters[i] != null) {
          j.style.setProperty('--rv-top', `${jalonCenters[i]}px`);
        }
      });
    };

    // Applique la progression du scroll mobile : vehicule, remplissage,
    // jalons. progress 0..1 = du premier au dernier point.
    const applyMobile = () => {
      if (!scene || jalonCenters.length === 0) return;
      const first = jalonCenters[0];
      const last = jalonCenters[jalonCenters.length - 1];
      const span = Math.max(last - first, 1);

      // Le vehicule vise le centre du viewport : on mesure ou tombe cette
      // ligne dans le repere de la scene, bornee entre premier et dernier
      // point.
      const sceneTop = scene.getBoundingClientRect().top;
      const focusLine = window.innerHeight * 0.5 - sceneTop;
      const vy = Math.min(Math.max(focusLine, first), last);
      const progress = (vy - first) / span;

      // Position du vehicule (px depuis le haut de la scene).
      if (rvVehicule) {
        rvVehicule.style.setProperty('--rv-vehicule-top', `${vy}px`);
        rvVehicule.classList.toggle('is-visible', progress > 0.001);
      }
      // Remplissage : hauteur du brin plein depuis le haut, en px absolus
      // (le conteneur .rv-brins commence a 0.25rem du haut ; on remplit
      // jusqu'a la ligne du vehicule, mesuree depuis ce meme haut).
      if (rvFill) {
        // rv-brins a top:0.25rem ; hauteur remplie = vy - 0.25rem (min 0).
        const filled = Math.max(vy - 4, 0);
        rvFill.style.height = `${filled}px`;
      }
      // Jalons : actif = le plus proche atteint ; passes = au-dessus du
      // vehicule.
      let activeIdx = 0;
      for (let i = 0; i < jalonCenters.length; i += 1) {
        if (vy >= jalonCenters[i] - 4) activeIdx = i;
      }
      rvJalons.forEach((j, i) => {
        j.classList.toggle('is-passed', i < activeIdx);
        j.classList.toggle('is-active', i === activeIdx && progress > 0.001);
      });
    };

    const mobileLoop = () => {
      applyMobile();
      mobileRaf = window.requestAnimationFrame(mobileLoop);
    };

    // Fondu d'entree des temoignages (IntersectionObserver) : classe
    // is-inview posee quand le bloc entre dans le viewport.
    let io: IntersectionObserver | null = null;
    const enableMobile = () => {
      if (mobileOn) return;
      mobileOn = true;
      section.setAttribute('data-rv-ready', '');
      // rv-fill pilote en px (on neutralise le fallback % CSS).
      if (rvFill) rvFill.style.setProperty('bottom', 'auto');
      measureMobile();
      io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-inview');
            }
          });
        },
        { rootMargin: '0px 0px -12% 0px', threshold: 0.15 }
      );
      items.forEach((el) => io?.observe(el));
      applyMobile();
      mobileRaf = window.requestAnimationFrame(mobileLoop);
    };

    const disableMobile = () => {
      if (!mobileOn) return;
      mobileOn = false;
      section.removeAttribute('data-rv-ready');
      window.cancelAnimationFrame(mobileRaf);
      if (io) {
        io.disconnect();
        io = null;
      }
      items.forEach((el) => el.classList.remove('is-inview'));
      rvJalons.forEach((j) => {
        j.classList.remove('is-active');
        j.classList.remove('is-passed');
      });
      if (rvFill) rvFill.style.height = '0px';
      if (rvVehicule) rvVehicule.classList.remove('is-visible');
    };

    const sync = () => {
      if (reduce) {
        disable();
        disableMobile();
        // Reduced-motion : on rend quand meme les temoignages visibles.
        section.setAttribute('data-rv-ready', '');
        return;
      }
      if (mqEnhance.matches) {
        disableMobile();
        enable();
      } else if (mqMobile.matches) {
        disable();
        enableMobile();
      } else {
        disable();
        disableMobile();
      }
    };

    sync();
    if (mqEnhance.addEventListener) {
      mqEnhance.addEventListener('change', sync);
      mqMobile.addEventListener('change', sync);
    } else if ((mqEnhance as any).addListener) {
      (mqEnhance as any).addListener(sync);
      (mqMobile as any).addListener(sync);
    }
    window.addEventListener('resize', () => {
      measureRail();
      if (mobileOn) measureMobile();
    });
  }

  if (document.readyState !== 'loading') {
    initTemoignages();
  } else {
    document.addEventListener('DOMContentLoaded', initTemoignages, {
      once: true,
    });
  }
  document.addEventListener('astro:page-load', initTemoignages);
</script>
