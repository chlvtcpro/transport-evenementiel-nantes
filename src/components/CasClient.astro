---
/*
  Section #cas-client de Cortege.
  La section qui fait signer : un cas phare nomme et chiffre raconte en
  trois temps (defi, action, resultat) avec ses stats en evidence, puis
  des cartes temoignages en support. Tone dark (--green-900), titres
  --on-dark, corps --on-dark a 0.8. Display en Fraunces.

  Le cas phare domine visuellement, les temoignages sont en appui. Slot
  image prevu cote SmartImage pour une photo reelle du cas, non active
  ici (aucun visuel fourni), fallback typographique propre.

  ATTENTION : les temoignages ci-dessous sont des PLACEHOLDERS. Voir le
  commentaire au dessus de la table TEMOIGNAGES avant mise en ligne.
*/
import Eyebrow from './Eyebrow.astro';
import ButtonArrow from './ButtonArrow.astro';

// En-tete de section.
const H2 = 'Le genre de logistique que personne ne veut gérer seul.';

// Cas phare : reel, mis en avant. Recit en 3 temps + 3 stats.
const CAS_PHARE = {
  tag: 'Mariage international',
  titre: 'Deux jours, quarante-neuf invités, zéro accroc.',
  defi:
    'Des invités arrivant par vagues en gare de Nantes, un site événementiel à desservir, une cérémonie en mairie, une réception, et des retours de nuit à organiser sur deux jours.',
  action:
    'Transport Événementiel Nantes a dimensionné et coordonné plusieurs véhicules et un autocar, géré les rotations, les transferts mairie et les navettes tardives. Un seul interlocuteur pour toute la mariée.',
  resultat:
    'Chaque invité au bon endroit au bon moment, sans que les mariés aient à gérer un seul trajet.',
  stats: [
    { valeur: '49', label: 'invités transportés' },
    { valeur: '2 jours', label: 'de coordination continue' },
    { valeur: '1', label: 'interlocuteur unique' },
  ],
};

// =====================================================================
// EXEMPLES DE DEMONSTRATION, A REMPLACER PAR DE VRAIS VERBATIM CLIENTS.
// ---------------------------------------------------------------------
// ATTENTION : les 5 temoignages ci-dessous sont des EXEMPLES fictifs
// crees uniquement pour tester le rendu (mini-carte compacte au repos,
// detail complet au clic). Chaque type d'evenement est different pour
// montrer la variete. NE PAS PUBLIER ces textes tels quels : remplacer
// `accroche`, `detail`, `auteur` par de vrais retours clients avant
// mise en ligne. Le mot DEMO en tete de chaque accroche est un garde-fou
// visuel a retirer avec les vrais verbatim.
// =====================================================================
const TEMOIGNAGES = [
  {
    type: 'Mariage',
    accroche: 'DEMO. Tous nos invités au bon endroit, au bon moment.',
    auteur: 'Prénom N.',
    role: 'Mariage, Loire-Atlantique',
    detail:
      'Transport Événementiel Nantes a coordonné les navettes entre la gare, la mairie et le lieu de réception sur deux jours. Les invités arrivaient par vagues, tout a été fluide, y compris les retours de nuit. Nous n\'avons eu à gérer aucun trajet.',
  },
  {
    type: 'Séminaire d\'entreprise',
    accroche: 'DEMO. Collaborateurs transportés sans le moindre retard.',
    auteur: 'Responsable événementiel',
    role: 'Séminaire, secteur tertiaire',
    detail:
      'Transferts gare et aéroport, navettes inter-sites et rotations sur trois jours de séminaire. Un interlocuteur unique suivait notre dossier, avec une facturation simple et centralisée. Zéro chauffeur à piloter de notre côté.',
  },
  {
    type: 'Transfert corporate',
    accroche: 'DEMO. Une flotte de berlines cadrée à la minute près.',
    auteur: 'Direction générale',
    role: 'Transfert dirigeants, Nantes',
    detail:
      'Pour l\'accueil d\'une délégation, Transport Événementiel Nantes a mobilisé plusieurs berlines avec chauffeurs, des horaires précis et un point de contact réactif. Chaque déplacement était anticipé, les temps d\'attente réduits au minimum.',
  },
  {
    type: 'Navette de groupe',
    accroche: 'DEMO. Plusieurs centaines de personnes, une seule équipe.',
    auteur: 'Organisation associative',
    role: 'Rassemblement, Grand Ouest',
    detail:
      'Transport Événementiel Nantes a assemblé berlines, vans et autocars pour transporter un grand groupe entre plusieurs sites. Le dimensionnement de la flotte, les rotations et les itinéraires ont été gérés de bout en bout, sans faille de coordination.',
  },
  {
    type: 'Événement média',
    accroche: 'DEMO. Une logistique invisible, une couverture sereine.',
    auteur: 'Régie événementielle',
    role: 'Événement média, Loire-Atlantique',
    detail:
      'Sur un événement à forte contrainte horaire, les équipes techniques et les intervenants ont été acheminés à l\'heure sur chaque créneau. Transport Événementiel Nantes a absorbé les imprévus de planning en temps réel, sans jamais impacter le déroulé.',
  },
];

// Recit du cas phare structure en temps, pour un rendu regulier.
const RECIT = [
  { label: 'Le défi', texte: CAS_PHARE.defi },
  { label: 'Notre action', texte: CAS_PHARE.action },
  { label: 'Le résultat', texte: CAS_PHARE.resultat },
];

const CTA_PHRASE = 'Votre événement mérite la même tranquillité.';
---

<section
  id="cas-client"
  data-tone="dark"
  class="relative bg-green-900 py-section text-on-dark scroll-mt-24"
>
  <div class="container">
    <!-- En-tete : cascade eyebrow, H2 -->
    <div class="max-w-3xl" data-reveal-stagger="120">
      <div data-reveal>
        <Eyebrow tone="dark">Ils nous ont fait confiance</Eyebrow>
      </div>
      <h2 class="type-h2 mt-6 text-on-dark" data-reveal>{H2}</h2>
    </div>

    <!-- BLOC 1 : cas phare nomme, en vedette -->
    <article class="cas-phare mt-14 md:mt-16" data-reveal-stagger="120">
      <div class="cas-phare-inner">
        <!-- Colonne recit -->
        <div class="cas-recit" data-reveal>
          <span class="cas-tag type-eyebrow text-gold">{CAS_PHARE.tag}</span>
          <h3 class="cas-titre mt-4 text-on-dark">{CAS_PHARE.titre}</h3>

          <dl class="mt-8 flex flex-col gap-6">
            {
              RECIT.map((temps) => (
                <div class="cas-temps">
                  <dt class="type-eyebrow text-on-dark/[0.85]">{temps.label}</dt>
                  <dd class="type-body mt-2 text-on-dark/[0.92]">{temps.texte}</dd>
                </div>
              ))
            }
          </dl>
        </div>

        <!-- Colonne stats en evidence -->
        <div class="cas-stats" data-reveal-stagger="120">
          {
            CAS_PHARE.stats.map((stat) => (
              <div class="cas-stat" data-reveal>
                <span class="cas-stat-valeur text-gold">{stat.valeur}</span>
                <span class="cas-stat-label type-nav mt-1 text-on-dark/[0.92]">
                  {stat.label}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </article>
  </div>

  <!-- ============================================================
       BLOC 2 : temoignages (EXEMPLES DEMO) en MINI-CARTES.
       Rangee de mini-cartes compactes en defilement horizontal
       (scroll-snap, swipe tactile mobile, coherent avec Lenis car
       c'est un scroll natif independant du scroll vertical). Au clic
       sur une carte : une modale s'ouvre avec le detail complet du
       temoignage. Fermeture au clic sur le fond, sur la croix, ou via
       Echap. Transitions douces (--ease). Fallback JS off : les cartes
       restent lisibles (accroche visible) et le detail est present en
       DOM dans la modale (accessible au clavier via le lien natif).
       ATTENTION : contenu de DEMONSTRATION a remplacer (voir la table
       TEMOIGNAGES et ses commentaires).
       ============================================================ -->
  <div class="container">
    <div class="temoignages-head mt-16 md:mt-20" data-reveal>
      <Eyebrow tone="dark">Ce qu'ils en disent</Eyebrow>
      <p class="type-nav mt-3 text-on-dark/[0.92]">
        Cliquez sur une carte pour lire le détail de la prestation.
      </p>
    </div>
  </div>

  <div
    class="temoignages-track"
    role="list"
    aria-label="Témoignages clients"
    data-temoignages-track
  >
    {
      TEMOIGNAGES.map((t, i) => (
        <button
          type="button"
          class="temoignage-mini"
          role="listitem"
          data-temoignage
          data-index={i}
          aria-haspopup="dialog"
        >
          <span class="temoignage-mini-type type-eyebrow text-gold">
            {t.type}
          </span>
          <span class="temoignage-mini-accroche type-body text-on-dark/[0.92]">
            {t.accroche}
          </span>
          <span class="temoignage-mini-pied mt-auto">
            <span class="temoignage-mini-auteur block text-on-dark">
              {t.auteur}
            </span>
            <span class="type-nav block text-on-dark/[0.85]">{t.role}</span>
          </span>
          <span class="temoignage-mini-lire type-nav text-gold" aria-hidden="true">
            Lire le détail
          </span>
        </button>
      ))
    }
  </div>

  <!-- Donnees des temoignages serialisees pour la modale (lues en JS).
       Format JSON inerte, non execute. -->
  <script
    type="application/json"
    data-temoignages-data
    set:html={JSON.stringify(TEMOIGNAGES)}
  />

  <!-- Modale de detail : un seul noeud, alimente en JS au clic.
       hidden par defaut ; ouverte via [data-open]. -->
  <div
    class="temoignage-modale"
    data-temoignage-modale
    role="dialog"
    aria-modal="true"
    aria-labelledby="temoignage-modale-type"
    hidden
  >
    <div class="temoignage-modale-fond" data-temoignage-close></div>
    <div class="temoignage-modale-carte" role="document">
      <button
        type="button"
        class="temoignage-modale-fermer"
        data-temoignage-close
        aria-label="Fermer le témoignage"
      >
        <span aria-hidden="true"></span>
      </button>
      <span class="temoignage-guillemet text-gold" aria-hidden="true">
        &ldquo;
      </span>
      <p
        id="temoignage-modale-type"
        class="temoignage-modale-type type-eyebrow text-gold"
        data-temoignage-modale-type
      ></p>
      <blockquote
        class="temoignage-modale-detail type-body text-on-dark/[0.92]"
        data-temoignage-modale-detail
      ></blockquote>
      <footer class="temoignage-modale-pied mt-6">
        <span
          class="temoignage-modale-auteur block text-on-dark"
          data-temoignage-modale-auteur
        ></span>
        <span
          class="type-nav mt-0.5 block text-on-dark/[0.85]"
          data-temoignage-modale-role
        ></span>
      </footer>
    </div>
  </div>

  <div class="container">
    <!-- CTA de fin de section, centre -->
    <div class="mt-16 flex flex-col items-center text-center md:mt-20" data-reveal>
      <p class="type-body mb-6 max-w-md text-on-dark/[0.92]">{CTA_PHRASE}</p>
      <ButtonArrow variant="solid" href="#formulaire-devis" label="Demander un devis" />
    </div>
  </div>
</section>

<style>
  /* Cas phare : bloc large et premium, il domine la section. Fond
     legerement releve du fond ambiant, fin liseré doré, coins doux. */
  .cas-phare {
    background-color: var(--green-800);
    border: 1px solid rgba(201, 162, 75, 0.22);
    border-radius: 22px;
    box-shadow: 0 30px 70px -40px rgba(0, 0, 0, 0.6);
    overflow: hidden;
  }

  /* Grille interne : recit large, stats en colonne d'appui a droite. */
  .cas-phare-inner {
    display: grid;
    gap: 2.5rem;
    padding: clamp(1.75rem, 4vw, 3.25rem);
  }

  @media (min-width: 1024px) {
    .cas-phare-inner {
      grid-template-columns: 1.6fr 1fr;
      gap: 3.5rem;
      align-items: center;
    }
  }

  .cas-tag {
    display: inline-block;
  }

  /* Titre du cas : display Fraunces, il porte le recit. */
  .cas-titre {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: clamp(1.85rem, 3.2vw, 2.85rem);
    line-height: 1.12;
    letter-spacing: -0.01em;
  }

  /* Colonne stats : separateur dore fin a gauche en desktop. */
  .cas-stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .cas-stats {
      padding-left: 3.5rem;
      border-left: 1px solid rgba(201, 162, 75, 0.22);
    }
  }

  .cas-stat {
    display: flex;
    flex-direction: column;
  }

  /* Valeur de stat en evidence : Clash Display, dore, gros. */
  .cas-stat-valeur {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 4vw, 3.25rem);
    line-height: 1;
  }

  /* ============================================================
     TEMOIGNAGES : mini-cartes en defilement horizontal, detail au clic.
     Rangee de mini-cartes compactes (scroll-snap, swipe tactile). Au
     clic : ouverture d'une modale avec le detail complet.
     ============================================================ */

  /* Piste horizontale : scroll natif avec snap, padding lateral aligne
     sur le container via clamp. Barre de defilement masquee. Fallback
     JS off : les mini-cartes restent visibles et scrollables. */
  .temoignages-track {
    display: flex;
    gap: 1.25rem;
    padding: 0.5rem clamp(1.25rem, 5vw, 2rem) 1.5rem;
    margin-top: 2rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .temoignages-track::-webkit-scrollbar {
    display: none;
  }

  /* Mini-carte compacte : bouton pleine surface, cliquable. Fond
     --green-800, coins doux, fin liseré doré, texte contraste. */
  .temoignage-mini {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 0 0 auto;
    width: min(80vw, 18.5rem);
    min-height: 15rem;
    padding: 1.75rem;
    text-align: left;
    background-color: var(--green-800);
    border: 1px solid rgba(201, 162, 75, 0.2);
    border-radius: 18px;
    scroll-snap-align: start;
    cursor: pointer;
    transition:
      transform 400ms var(--ease),
      border-color 400ms var(--ease),
      background-color 400ms var(--ease);
  }
  .temoignage-mini:hover,
  .temoignage-mini:focus-visible {
    outline: none;
    transform: translateY(-4px);
    border-color: rgba(201, 162, 75, 0.5);
    background-color: var(--green-700);
  }
  .temoignage-mini:focus-visible {
    box-shadow: 0 0 0 2px rgba(201, 162, 75, 0.5);
  }

  .temoignage-mini-type {
    display: inline-block;
  }

  /* Accroche au repos : essentiel, contraste, non italique (lisible). */
  .temoignage-mini-accroche {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .temoignage-mini-pied {
    font-family: var(--font-body);
    font-size: 0.95rem;
  }
  .temoignage-mini-auteur {
    font-weight: 500;
  }

  /* Indice "Lire le detail" dore, discret, souligne l'affordance clic. */
  .temoignage-mini-lire {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
    opacity: 0.9;
  }
  .temoignage-mini-lire::after {
    content: '';
    width: 0.9rem;
    height: 1px;
    background-color: currentColor;
    transition: width 300ms var(--ease);
  }
  .temoignage-mini:hover .temoignage-mini-lire::after,
  .temoignage-mini:focus-visible .temoignage-mini-lire::after {
    width: 1.6rem;
  }

  /* Guillemet stylise en accent Fraunces (reutilise dans la modale). */
  .temoignage-guillemet {
    font-family: var(--font-display);
    font-size: 3.5rem;
    line-height: 0.6;
    height: 1.4rem;
    opacity: 0.8;
  }

  /* ---- Modale de detail ---- */
  .temoignage-modale {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .temoignage-modale[hidden] {
    display: none;
  }

  /* Fond assombri, ferme au clic. Transitionne l'opacite. */
  .temoignage-modale-fond {
    position: absolute;
    inset: 0;
    background-color: rgba(6, 12, 9, 0.7);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 350ms var(--ease);
  }

  /* Carte modale : fond --green-800, liseré doré, coins doux, animation
     douce d'apparition (translation + opacite). */
  .temoignage-modale-carte {
    position: relative;
    width: min(34rem, 100%);
    max-height: 85vh;
    overflow-y: auto;
    padding: clamp(1.75rem, 4vw, 2.75rem);
    background-color: var(--green-800);
    border: 1px solid rgba(201, 162, 75, 0.28);
    border-radius: 22px;
    box-shadow: 0 40px 90px -40px rgba(0, 0, 0, 0.75);
    opacity: 0;
    transform: translateY(16px) scale(0.98);
    transition:
      opacity 350ms var(--ease),
      transform 350ms var(--ease);
  }

  /* Etat ouvert : fond visible + carte posee. Pilote par [data-open]. */
  .temoignage-modale[data-open] .temoignage-modale-fond {
    opacity: 1;
  }
  .temoignage-modale[data-open] .temoignage-modale-carte {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .temoignage-modale-type {
    display: block;
    margin-top: 0.5rem;
  }

  .temoignage-modale-detail {
    margin: 0.75rem 0 0;
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.55;
  }

  /* Bouton croix : coin haut droit, cible tactile confortable. */
  .temoignage-modale-fermer {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--line-on-dark);
    background-color: transparent;
    cursor: pointer;
    transition:
      border-color 250ms var(--ease),
      background-color 250ms var(--ease);
  }
  .temoignage-modale-fermer:hover,
  .temoignage-modale-fermer:focus-visible {
    outline: none;
    border-color: var(--gold);
    background-color: rgba(201, 162, 75, 0.12);
  }
  .temoignage-modale-fermer span {
    position: relative;
    width: 1rem;
    height: 1rem;
  }
  .temoignage-modale-fermer span::before,
  .temoignage-modale-fermer span::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: var(--on-dark);
  }
  .temoignage-modale-fermer span::before {
    transform: rotate(45deg);
  }
  .temoignage-modale-fermer span::after {
    transform: rotate(-45deg);
  }

  /* Reduced motion : on coupe les transitions d'ouverture. */
  @media (prefers-reduced-motion: reduce) {
    .temoignage-modale-fond,
    .temoignage-modale-carte {
      transition: none;
    }
    .temoignage-mini {
      transition: none;
    }
  }
</style>

<script>
  /* ============================================================
     Temoignages : mini-cartes -> detail en modale.
     Au clic sur une mini-carte, on lit son index, on recupere le
     temoignage correspondant dans les donnees JSON serialisees, on
     remplit la modale et on l'ouvre. Fermeture au clic sur le fond,
     sur la croix, ou via la touche Echap. Le focus revient sur la
     carte d'origine a la fermeture (accessibilite).

     Le defilement horizontal des mini-cartes est un scroll natif
     (CSS overflow-x + scroll-snap), independant du scroll vertical :
     aucune interference avec Lenis.
     ============================================================ */
  type Temoignage = {
    type: string;
    accroche: string;
    auteur: string;
    role: string;
    detail: string;
  };

  const dataNode = document.querySelector<HTMLScriptElement>(
    '[data-temoignages-data]'
  );
  const modale = document.querySelector<HTMLElement>('[data-temoignage-modale]');
  const cartes = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-temoignage]')
  );

  if (dataNode && modale && cartes.length) {
    let temoignages: Temoignage[] = [];
    try {
      temoignages = JSON.parse(dataNode.textContent ?? '[]');
    } catch {
      temoignages = [];
    }

    const elType = modale.querySelector<HTMLElement>(
      '[data-temoignage-modale-type]'
    );
    const elDetail = modale.querySelector<HTMLElement>(
      '[data-temoignage-modale-detail]'
    );
    const elAuteur = modale.querySelector<HTMLElement>(
      '[data-temoignage-modale-auteur]'
    );
    const elRole = modale.querySelector<HTMLElement>(
      '[data-temoignage-modale-role]'
    );
    const fermeBtn = modale.querySelector<HTMLButtonElement>(
      '.temoignage-modale-fermer'
    );

    let lastFocused: HTMLElement | null = null;

    const open = (index: number, origin: HTMLElement): void => {
      const t = temoignages[index];
      if (!t) return;
      if (elType) elType.textContent = t.type;
      if (elDetail) elDetail.textContent = t.detail;
      if (elAuteur) elAuteur.textContent = t.auteur;
      if (elRole) elRole.textContent = t.role;

      lastFocused = origin;
      modale.hidden = false;
      // Force un reflow avant d'ajouter [data-open] pour jouer la transition.
      void modale.offsetWidth;
      modale.setAttribute('data-open', '');
      document.body.style.overflow = 'hidden';
      fermeBtn?.focus();
    };

    const close = (): void => {
      modale.removeAttribute('data-open');
      document.body.style.overflow = '';
      // Attend la fin de la transition avant de masquer completement.
      const finish = (): void => {
        modale.hidden = true;
        modale.removeEventListener('transitionend', finish);
      };
      // Fallback si aucune transition (reduced-motion) : ferme direct.
      const reduced = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;
      if (reduced) {
        modale.hidden = true;
      } else {
        const carte = modale.querySelector<HTMLElement>(
          '.temoignage-modale-carte'
        );
        carte?.addEventListener('transitionend', finish, { once: true });
        // Garde-fou : masque apres 500ms meme si transitionend manque.
        window.setTimeout(() => {
          if (!modale.hasAttribute('data-open')) modale.hidden = true;
        }, 500);
      }
      lastFocused?.focus();
    };

    cartes.forEach((carte) => {
      carte.addEventListener('click', () => {
        const index = Number(carte.dataset.index);
        open(index, carte);
      });
    });

    // Fermeture : elements marques [data-temoignage-close] (fond + croix).
    modale.querySelectorAll('[data-temoignage-close]').forEach((el) => {
      el.addEventListener('click', close);
    });

    // Echap ferme la modale si ouverte.
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modale.hasAttribute('data-open')) {
        close();
      }
    });
  }
</script>
