---
/*
  Section #cas-client de Cortege.
  Section de preuve sociale : un carrousel de cartes temoignages
  cliquables sous l'eyebrow "Ils nous ont fait confiance". Au clic, une
  modale devoile le detail complet du temoignage. Tone dark (--green-900),
  titres --on-dark, corps --on-dark a 0.92. Display en Fraunces.

  L'ancre #cas-client est conservee : la navigation (Header, Footer, Hero)
  pointe "Realisations" vers cette section temoignages.

  Carte 1 = temoignage reel ; cartes 2 a 5 = exemples representatifs
  (voir la table TEMOIGNAGES).
*/
import Eyebrow from './Eyebrow.astro';
import ButtonArrow from './ButtonArrow.astro';

// =====================================================================
// TEMOIGNAGES DU CARROUSEL "ILS NOUS ONT FAIT CONFIANCE".
// ---------------------------------------------------------------------
// La carte 1 (Titouan N.) est un VRAI temoignage client, a afficher
// tel quel. Les cartes 2 a 5 sont des EXEMPLES representatifs, credibles
// mais fictifs : a remplacer par de vrais verbatims des qu'ils sont
// disponibles. Prenoms et noms volontairement partiels ou generiques,
// aucun nom d'entreprise reelle associe a ces temoignages.
// =====================================================================
const TEMOIGNAGES = [
  {
    // Carte 1 : temoignage reel, publie tel quel.
    type: 'Mariage',
    accroche: 'Ponctualité parfaite, une équipe fiable et facile à joindre.',
    auteur: 'Titouan N.',
    role: 'Mariage, Loire-Atlantique',
    detail:
      'Simon a assuré le transport de nos invités le jour de notre mariage avec un grand professionnalisme. Très à l\'écoute, transparent et réactif, il a pris le temps d\'optimiser les trajets pour trouver le meilleur compromis entre le confort des invités et le budget. Tout s\'est déroulé parfaitement : ponctualité, excellente communication et super organisation. Nous recommandons à 100 pour cent.',
  },
  {
    type: 'Séminaire d\'entreprise',
    accroche: 'Une navette séminaire d\'entreprise coordonnée sans le moindre retard sur deux jours.',
    auteur: 'Camille R.',
    role: 'Séminaire, secteur tertiaire',
    detail:
      'Pour notre séminaire d\'entreprise à Nantes, nous avions besoin de navettes entre l\'hôtel, le lieu de réunion et un restaurant. Le transport des participants a été entièrement coordonné par un seul interlocuteur, avec les transferts gare et les rotations. Aucun trajet à gérer de notre côté.',
  },
  {
    type: 'Transfert corporate',
    accroche: 'Un transfert de dirigeants à Nantes avec une flotte de berlines cadrée à la minute.',
    auteur: 'Julien M.',
    role: 'Transfert dirigeants, Nantes',
    detail:
      'Nous cherchions un transport de dirigeants fiable entre la gare de Nantes, le siège et un dîner d\'affaires. Véhicules impeccables, chauffeurs ponctuels, coordination sans faille. Le niveau attendu pour un transfert corporate en Loire-Atlantique.',
  },
  {
    type: 'Navette de groupe',
    accroche: 'Une navette de groupe de plusieurs centaines de personnes, orchestrée par une seule équipe.',
    auteur: 'Sophie L.',
    role: 'Rassemblement, Grand Ouest',
    detail:
      'Pour notre rassemblement dans le Grand Ouest, il fallait un transport de groupe de grande capacité depuis plusieurs points. Berlines, vans et autocars dimensionnés selon le volume, rotations enchaînées sans attente. Une navette événementielle clé en main.',
  },
  {
    type: 'Mariage',
    accroche: 'Des navettes de mariage et retours de nuit gérés sans qu\'on y pense.',
    auteur: 'Marie et Thomas D.',
    role: 'Mariage, Vendée',
    detail:
      'Pour notre mariage en Vendée, le transport des invités et les navettes de nuit étaient notre inquiétude. Tout a été orchestré : transferts, rotations, retours de fin de soirée en sécurité. Un transport de mariage dans le Grand Ouest géré de bout en bout.',
  },
];

const CTA_PHRASE = 'Votre événement mérite la même tranquillité.';
---

<section
  id="cas-client"
  data-tone="dark"
  class="relative bg-green-900 py-section text-on-dark scroll-mt-24"
>
  <!-- ============================================================
       SECTION temoignages "Ils nous ont fait confiance" en MUR / MOSAIQUE.
       Tous les temoignages sont visibles d'un coup, sans defilement
       lateral. Le vrai avis (Titouan N., index 0) est mis en VEDETTE :
       grande carte a gauche, 5 etoiles dorees, grand guillemet dore, son
       detail complet affiche directement. Les 4 exemples (Camille R.,
       Julien M., Sophie L., Marie et Thomas D.) sont disposes autour en
       cartes plus petites, cliquables : au clic, une modale devoile le
       detail complet. Mobile : empilement une colonne, Titouan en tete.
       Fallback JS off : cartes lisibles (accroche visible), detail present
       en DOM dans la modale (accessible au clavier).
       ============================================================ -->
  <div class="container">
    <div class="temoignages-head" data-reveal>
      <Eyebrow tone="dark">Ils nous ont fait confiance</Eyebrow>
      <p class="type-nav mt-3 text-on-dark/[0.92]">
        Le récit d'un client, et des prestations menées sans accroc.
      </p>
    </div>

    <div class="temoignages-mur" role="list" aria-label="Témoignages clients" data-reveal>
      {
        TEMOIGNAGES.map((t, i) =>
          i === 0 ? (
            <article class="temoignage-vedette" role="listitem">
              <span class="temoignage-etoiles" aria-label="Cinq étoiles sur cinq">
                <span aria-hidden="true">★★★★★</span>
              </span>
              <span class="temoignage-vedette-guillemet text-gold" aria-hidden="true">
                &ldquo;
              </span>
              <span class="temoignage-vedette-type type-eyebrow text-gold">
                {t.type}
              </span>
              <blockquote class="temoignage-vedette-detail">{t.detail}</blockquote>
              <footer class="temoignage-vedette-pied">
                <span class="temoignage-vedette-auteur block text-on-dark">
                  {t.auteur}
                </span>
                <span class="type-nav block text-on-dark/[0.85]">{t.role}</span>
              </footer>
            </article>
          ) : (
            <button
              type="button"
              class="temoignage-mini"
              role="listitem"
              data-temoignage
              data-index={i}
              aria-haspopup="dialog"
            >
              <span class="temoignage-mini-type type-eyebrow text-gold">
                {t.type}
              </span>
              <span class="temoignage-mini-accroche">{t.accroche}</span>
              <span class="temoignage-mini-pied mt-auto">
                <span class="temoignage-mini-auteur block text-on-dark">
                  {t.auteur}
                </span>
                <span class="type-nav block text-on-dark/[0.85]">{t.role}</span>
              </span>
              <span class="temoignage-mini-lire type-nav text-gold" aria-hidden="true">
                Lire le détail
              </span>
            </button>
          )
        )
      }
    </div>
  </div>

  <!-- Donnees des temoignages serialisees pour la modale (lues en JS).
       Format JSON inerte, non execute. -->
  <script
    type="application/json"
    data-temoignages-data
    set:html={JSON.stringify(TEMOIGNAGES)}
  />

  <!-- Modale de detail : un seul noeud, alimente en JS au clic.
       hidden par defaut ; ouverte via [data-open]. -->
  <div
    class="temoignage-modale"
    data-temoignage-modale
    role="dialog"
    aria-modal="true"
    aria-labelledby="temoignage-modale-type"
    hidden
  >
    <div class="temoignage-modale-fond" data-temoignage-close></div>
    <div class="temoignage-modale-carte" role="document">
      <button
        type="button"
        class="temoignage-modale-fermer"
        data-temoignage-close
        aria-label="Fermer le témoignage"
      >
        <span aria-hidden="true"></span>
      </button>
      <span class="temoignage-guillemet text-gold" aria-hidden="true">
        &ldquo;
      </span>
      <p
        id="temoignage-modale-type"
        class="temoignage-modale-type type-eyebrow text-gold"
        data-temoignage-modale-type
      ></p>
      <blockquote
        class="temoignage-modale-detail type-body"
        data-temoignage-modale-detail
      ></blockquote>
      <footer class="temoignage-modale-pied mt-6">
        <span
          class="temoignage-modale-auteur block text-on-dark"
          data-temoignage-modale-auteur
        ></span>
        <span
          class="type-nav mt-0.5 block text-on-dark/[0.85]"
          data-temoignage-modale-role
        ></span>
      </footer>
    </div>
  </div>

  <div class="container">
    <!-- CTA de fin de section, centre -->
    <div class="mt-16 flex flex-col items-center text-center md:mt-20" data-reveal>
      <p class="type-body mb-6 max-w-md text-on-dark/[0.92]">{CTA_PHRASE}</p>
      <ButtonArrow variant="solid" href="#formulaire-devis" label="Demander un devis" />
    </div>
  </div>
</section>

<style>
  /* ============================================================
     TEMOIGNAGES : MUR / MOSAIQUE. Tout visible, aucun scroll lateral.
     Grille asymetrique : carte vedette (Titouan) a gauche sur 2 rangees,
     4 mini-cartes (exemples cliquables) reparties a droite. Mobile :
     une colonne, vedette en tete.
     ============================================================ */

  /* Grille du mur : colonne vedette large (1.5fr) + deux colonnes de
     mini-cartes (1fr chacune). La vedette occupe les deux rangees de la
     premiere colonne ; les 4 mini-cartes remplissent la grille 2x2 a
     droite. align-items: stretch pour des cartes de meme hauteur par
     rangee. */
  .temoignages-mur {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    grid-auto-rows: 1fr;
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  /* ---- Carte vedette (vrai avis, piece maitresse) ---- */
  .temoignage-vedette {
    position: relative;
    grid-column: 1;
    grid-row: 1 / span 2;
    display: flex;
    flex-direction: column;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    background-color: var(--green-800);
    border: 1px solid rgba(201, 162, 75, 0.4);
    border-radius: 22px;
    box-shadow: 0 30px 70px -45px rgba(0, 0, 0, 0.8);
    overflow: hidden;
  }
  /* Voile dore tres subtil dans le coin haut, pour distinguer la vedette. */
  .temoignage-vedette::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -30%;
    width: 70%;
    height: 80%;
    background: radial-gradient(
      circle,
      rgba(201, 162, 75, 0.16) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .temoignage-etoiles {
    position: relative;
    font-size: 1.05rem;
    letter-spacing: 0.15em;
    color: var(--gold);
    line-height: 1;
  }

  .temoignage-vedette-guillemet {
    position: relative;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 5rem;
    line-height: 0.5;
    height: 2rem;
    margin-top: 1rem;
    opacity: 0.85;
  }

  .temoignage-vedette-type {
    position: relative;
    display: inline-block;
    margin-top: 1.5rem;
  }

  .temoignage-vedette-detail {
    position: relative;
    margin: 1rem 0 0;
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 500;
    font-size: clamp(1.35rem, 1.9vw, 1.7rem);
    line-height: 1.32;
    letter-spacing: -0.01em;
    color: var(--on-dark);
    text-wrap: pretty;
  }

  .temoignage-vedette-pied {
    position: relative;
    margin-top: auto;
    padding-top: 1.75rem;
    font-family: var(--font-body);
    font-size: 1rem;
  }
  .temoignage-vedette-auteur {
    font-weight: 600;
  }

  /* Mini-carte (exemple) : bouton pleine surface, cliquable, dans la
     grille (plus de largeur fixe ni de scroll-snap). Fond --green-800,
     coins doux, fin liseré doré, texte contraste. */
  .temoignage-mini {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    min-height: 13rem;
    padding: 1.6rem;
    text-align: left;
    background-color: var(--green-800);
    border: 1px solid rgba(201, 162, 75, 0.2);
    border-radius: 18px;
    cursor: pointer;
    transition:
      transform 400ms var(--ease),
      border-color 400ms var(--ease),
      background-color 400ms var(--ease);
  }
  .temoignage-mini:hover,
  .temoignage-mini:focus-visible {
    outline: none;
    transform: translateY(-4px);
    border-color: rgba(201, 162, 75, 0.5);
    background-color: var(--green-700);
  }
  .temoignage-mini:focus-visible {
    box-shadow: 0 0 0 2px rgba(201, 162, 75, 0.5);
  }

  .temoignage-mini-type {
    display: inline-block;
  }

  /* Accroche au repos : essentiel, contraste, non italique (lisible).
     Couleur crème posee en direct (var(--on-dark) + opacity) plutot qu'en
     classe Tailwind text-on-dark/[0.92] : l'opacite arbitraire ne se
     resout pas sur une variable non-RGB et retombait sur un gris sombre. */
  .temoignage-mini-accroche {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: 1.2rem;
    line-height: 1.24;
    letter-spacing: -0.01em;
    color: var(--on-dark);
    opacity: 0.92;
  }

  .temoignage-mini-pied {
    font-family: var(--font-body);
    font-size: 0.95rem;
  }
  .temoignage-mini-auteur {
    font-weight: 500;
  }

  /* Indice "Lire le detail" dore, discret, souligne l'affordance clic. */
  .temoignage-mini-lire {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
    opacity: 0.9;
  }
  .temoignage-mini-lire::after {
    content: '';
    width: 0.9rem;
    height: 1px;
    background-color: currentColor;
    transition: width 300ms var(--ease);
  }
  .temoignage-mini:hover .temoignage-mini-lire::after,
  .temoignage-mini:focus-visible .temoignage-mini-lire::after {
    width: 1.6rem;
  }

  /* Guillemet stylise en accent Fraunces (reutilise dans la modale). */
  .temoignage-guillemet {
    font-family: var(--font-display);
    font-size: 3.5rem;
    line-height: 0.6;
    height: 1.4rem;
    opacity: 0.8;
  }

  /* ---- Modale de detail ---- */
  .temoignage-modale {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .temoignage-modale[hidden] {
    display: none;
  }

  /* Fond assombri, ferme au clic. Transitionne l'opacite. */
  .temoignage-modale-fond {
    position: absolute;
    inset: 0;
    background-color: rgba(6, 12, 9, 0.7);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 350ms var(--ease);
  }

  /* Carte modale : fond --green-800, liseré doré, coins doux, animation
     douce d'apparition (translation + opacite). */
  .temoignage-modale-carte {
    position: relative;
    width: min(34rem, 100%);
    max-height: 85vh;
    overflow-y: auto;
    padding: clamp(1.75rem, 4vw, 2.75rem);
    background-color: var(--green-800);
    border: 1px solid rgba(201, 162, 75, 0.28);
    border-radius: 22px;
    box-shadow: 0 40px 90px -40px rgba(0, 0, 0, 0.75);
    opacity: 0;
    transform: translateY(16px) scale(0.98);
    transition:
      opacity 350ms var(--ease),
      transform 350ms var(--ease);
  }

  /* Etat ouvert : fond visible + carte posee. Pilote par [data-open]. */
  .temoignage-modale[data-open] .temoignage-modale-fond {
    opacity: 1;
  }
  .temoignage-modale[data-open] .temoignage-modale-carte {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .temoignage-modale-type {
    display: block;
    margin-top: 0.5rem;
  }

  .temoignage-modale-detail {
    margin: 0.75rem 0 0;
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.55;
    /* Couleur crème en direct (meme raison que l'accroche) : evite le gris
       sombre du fallback Tailwind text-on-dark/[0.92] sur variable non-RGB. */
    color: var(--on-dark);
    opacity: 0.92;
  }

  /* Bouton croix : coin haut droit, cible tactile confortable. */
  .temoignage-modale-fermer {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--line-on-dark);
    background-color: transparent;
    cursor: pointer;
    transition:
      border-color 250ms var(--ease),
      background-color 250ms var(--ease);
  }
  .temoignage-modale-fermer:hover,
  .temoignage-modale-fermer:focus-visible {
    outline: none;
    border-color: var(--gold);
    background-color: rgba(201, 162, 75, 0.12);
  }
  .temoignage-modale-fermer span {
    position: relative;
    width: 1rem;
    height: 1rem;
  }
  .temoignage-modale-fermer span::before,
  .temoignage-modale-fermer span::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: var(--on-dark);
  }
  .temoignage-modale-fermer span::before {
    transform: rotate(45deg);
  }
  .temoignage-modale-fermer span::after {
    transform: rotate(-45deg);
  }

  /* ---- Responsive du mur ---- */

  /* Tablette : la vedette passe pleine largeur en tete, les 4 exemples
     se rangent en dessous sur deux colonnes. Plus de span de rangees. */
  @media (max-width: 1023px) {
    .temoignages-mur {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: auto;
    }
    .temoignage-vedette {
      grid-column: 1 / -1;
      grid-row: auto;
    }
  }

  /* Mobile : une seule colonne, empilement propre. La vedette (vrai avis)
     reste en tete, les exemples suivent. Aucun scroll horizontal. */
  @media (max-width: 639px) {
    .temoignages-mur {
      grid-template-columns: 1fr;
    }
    .temoignage-vedette {
      grid-column: 1;
    }
    .temoignage-mini {
      min-height: 0;
    }
  }

  /* Reduced motion : on coupe les transitions d'ouverture. */
  @media (prefers-reduced-motion: reduce) {
    .temoignage-modale-fond,
    .temoignage-modale-carte {
      transition: none;
    }
    .temoignage-mini {
      transition: none;
    }
  }
</style>

<script>
  /* ============================================================
     Temoignages : mini-cartes -> detail en modale.
     Au clic sur une mini-carte, on lit son index, on recupere le
     temoignage correspondant dans les donnees JSON serialisees, on
     remplit la modale et on l'ouvre. Fermeture au clic sur le fond,
     sur la croix, ou via la touche Echap. Le focus revient sur la
     carte d'origine a la fermeture (accessibilite).

     La carte vedette (Titouan, index 0) affiche son detail directement
     et n'est pas cliquable : seules les mini-cartes exemples ouvrent la
     modale. Le mur est une grille statique, aucun scroll lateral.
     ============================================================ */
  type Temoignage = {
    type: string;
    accroche: string;
    auteur: string;
    role: string;
    detail: string;
  };

  const dataNode = document.querySelector<HTMLScriptElement>(
    '[data-temoignages-data]'
  );
  const modale = document.querySelector<HTMLElement>('[data-temoignage-modale]');
  const cartes = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-temoignage]')
  );

  if (dataNode && modale && cartes.length) {
    let temoignages: Temoignage[] = [];
    try {
      temoignages = JSON.parse(dataNode.textContent ?? '[]');
    } catch {
      temoignages = [];
    }

    const elType = modale.querySelector<HTMLElement>(
      '[data-temoignage-modale-type]'
    );
    const elDetail = modale.querySelector<HTMLElement>(
      '[data-temoignage-modale-detail]'
    );
    const elAuteur = modale.querySelector<HTMLElement>(
      '[data-temoignage-modale-auteur]'
    );
    const elRole = modale.querySelector<HTMLElement>(
      '[data-temoignage-modale-role]'
    );
    const fermeBtn = modale.querySelector<HTMLButtonElement>(
      '.temoignage-modale-fermer'
    );

    let lastFocused: HTMLElement | null = null;

    const open = (index: number, origin: HTMLElement): void => {
      const t = temoignages[index];
      if (!t) return;
      if (elType) elType.textContent = t.type;
      if (elDetail) elDetail.textContent = t.detail;
      if (elAuteur) elAuteur.textContent = t.auteur;
      if (elRole) elRole.textContent = t.role;

      lastFocused = origin;
      modale.hidden = false;
      // Force un reflow avant d'ajouter [data-open] pour jouer la transition.
      void modale.offsetWidth;
      modale.setAttribute('data-open', '');
      document.body.style.overflow = 'hidden';
      fermeBtn?.focus();
    };

    const close = (): void => {
      modale.removeAttribute('data-open');
      document.body.style.overflow = '';
      // Attend la fin de la transition avant de masquer completement.
      const finish = (): void => {
        modale.hidden = true;
        modale.removeEventListener('transitionend', finish);
      };
      // Fallback si aucune transition (reduced-motion) : ferme direct.
      const reduced = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;
      if (reduced) {
        modale.hidden = true;
      } else {
        const carte = modale.querySelector<HTMLElement>(
          '.temoignage-modale-carte'
        );
        carte?.addEventListener('transitionend', finish, { once: true });
        // Garde-fou : masque apres 500ms meme si transitionend manque.
        window.setTimeout(() => {
          if (!modale.hasAttribute('data-open')) modale.hidden = true;
        }, 500);
      }
      lastFocused?.focus();
    };

    cartes.forEach((carte) => {
      carte.addEventListener('click', () => {
        const index = Number(carte.dataset.index);
        open(index, carte);
      });
    });

    // Fermeture : elements marques [data-temoignage-close] (fond + croix).
    modale.querySelectorAll('[data-temoignage-close]').forEach((el) => {
      el.addEventListener('click', close);
    });

    // Echap ferme la modale si ouverte.
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modale.hasAttribute('data-open')) {
        close();
      }
    });
  }
</script>
