---
/*
  Header : nav transparente par-dessus le hero, devient sticky
  avec fond vert profond condense au scroll (gere en JS via un
  IntersectionObserver sentinelle en haut de page).
*/
import ButtonArrow from './ButtonArrow.astro';

interface Props {
  /**
   * Contexte de fond. 'dark' (defaut) = accueil, header transparent
   * par-dessus le hero sombre, logo/liens clairs. 'light' = pages a fond
   * creme, logo en version foncee et liens en --ink pour rester lisibles.
   */
  theme?: 'light' | 'dark';
}
const { theme = 'dark' } = Astro.props;

// Sur fond clair, on sert la variante foncee du logo (texte #16241C, soleil
// dore inchange) ; sur fond sombre, la variante claire d'origine.
const logoSrc =
  theme === 'light'
    ? '/logo-transport-evenementiel-nantes-dark.svg'
    : '/logo-transport-evenementiel-nantes.svg';

// Liens d'ancre prefixes par '/' : fonctionnent depuis l'accueil ET depuis
// les pages blog (une ancre nue #... ne cible que la page courante).
const links = [
  { href: '/#comment-ca-marche', label: 'Comment ça marche' },
  { href: '/#offres', label: 'Offres' },
  { href: '/#cas-client', label: 'Réalisations' },
  { href: '/#differenciateurs', label: 'Notre approche' },
  { href: '/blog', label: 'Ressources' },
];
---

<header
  id="site-header"
  class:list={[
    'fixed inset-x-0 top-0 z-50 transition-all duration-500 ease-smooth',
    theme === 'light' && 'is-light',
  ]}
  data-state="top"
>
  <div
    class="container flex items-center justify-between gap-6 py-5 transition-all duration-500 ease-smooth"
  >
    <a
      href="/#hero"
      class="site-logo"
      aria-label="Transport Événementiel Nantes, accueil"
    >
      <img
        src={logoSrc}
        alt="Transport Événementiel Nantes"
        class="site-logo-img"
        width="860"
        height="240"
        decoding="async"
      />
    </a>

    <nav class="nav-desktop items-center" aria-label="Navigation principale">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="nav-link type-nav text-on-dark transition-colors duration-300 hover:text-gold"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="cta-desktop">
      <ButtonArrow variant="solid" href="/#formulaire-devis" label="Demander un devis" />
    </div>

    <!-- Declencheur menu mobile -->
    <button
      id="menu-toggle"
      class="menu-toggle flex h-10 w-10 items-center justify-center"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="relative block h-3 w-6">
        <span class="absolute left-0 top-0 h-px w-6 bg-on-dark transition-all duration-300"></span>
        <span class="absolute bottom-0 left-0 h-px w-6 bg-on-dark transition-all duration-300"></span>
      </span>
    </button>
  </div>

  <!-- Menu mobile. L'ouverture/fermeture est pilotee par l'attribut
       data-open et animee en CSS (grid-template-rows 0fr vers 1fr) dans le
       <style> scope ci-dessous. On n'utilise PAS de classes Tailwind
       arbitraires (grid-rows-[1fr]) ajoutees en JS : Tailwind ne genere que
       les classes qu'il voit statiquement dans les sources, donc une classe
       ajoutee dynamiquement n'a aucune regle CSS et le menu ne s'ouvre pas. -->
  <div
    id="mobile-menu"
    class="mobile-menu overflow-hidden bg-green-900/98 backdrop-blur"
    data-open="false"
  >
    <div class="mobile-menu-inner min-h-0">
      <nav class="container flex flex-col gap-5 py-8" aria-label="Navigation mobile">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="type-nav text-on-dark transition-colors hover:text-gold"
              data-mobile-link
            >
              {link.label}
            </a>
          ))
        }
        <div class="pt-2">
          <ButtonArrow variant="solid" href="/#formulaire-devis" label="Demander un devis" />
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  // Etat sticky : on condense le header apres avoir depasse le seuil.
  if (header) {
    const onScroll = () => {
      const scrolled = window.scrollY > 40;
      header.dataset.state = scrolled ? 'scrolled' : 'top';
      header.classList.toggle('is-condensed', scrolled);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Menu mobile : ouverture / fermeture pilotees par data-open (le CSS
  // scope gere l'animation d'ouverture). Fiable car la regle CSS existe
  // toujours, independamment du scan JIT de Tailwind.
  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      menu.dataset.open = String(open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
    };
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });
    menu.querySelectorAll('[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  }
</script>

<style>
  /* =========================================================
     Bascule desktop / mobile a 1180px (et non 1024px) : avec cinq
     liens plus le CTA, la barre ne tient plus sur une ligne entre
     1024 et 1180px. On bascule donc sur le burger plus tot pour ne
     jamais afficher une navigation cassee. Visibilite pilotee ici en
     CSS scope (pas via les utilitaires lg: de Tailwind) pour maitriser
     le point de bascule exact.
     ========================================================= */
  .nav-desktop,
  .cta-desktop {
    display: none;
  }
  .menu-toggle {
    display: inline-flex;
  }
  @media (min-width: 1180px) {
    .nav-desktop {
      display: flex;
      /* Gap fluide, strictement identique entre chaque lien. Se resserre
         progressivement vers les largeurs basses sans jamais provoquer
         de retour a la ligne. */
      gap: clamp(1.5rem, 2.2vw, 2.25rem);
    }
    .cta-desktop {
      display: block;
    }
    .menu-toggle {
      display: none;
    }
  }

  /* Liens de navigation : jamais coupes en deux, taille de police fluide
     et lisible (ne descend pas sous 15px). */
  .nav-link {
    white-space: nowrap;
    font-size: clamp(0.9rem, 1.1vw, 0.95rem);
  }

  /* Le libelle du bouton CTA (DEMANDER UN DEVIS) reste sur une seule
     ligne, la fleche alignee a droite du texte. */
  .cta-desktop :global(.type-button) {
    white-space: nowrap;
  }

  /* Logo SVG : hauteur fixe, largeur auto (le viewBox 860x240 preserve le
     ratio). Curseur pointer et leger fondu au survol. La version claire du
     SVG reste lisible sur le fond sombre du header. */
  .site-logo {
    display: inline-flex;
    align-items: center;
    transition: opacity 300ms var(--ease);
  }
  .site-logo:hover {
    opacity: 0.82;
  }
  .site-logo-img {
    display: block;
    height: 46px;
    width: auto;
  }
  @media (min-width: 640px) {
    .site-logo-img {
      height: 54px;
    }
  }

  /* Fond condense au scroll + filet dore fin en bas */
  #site-header.is-condensed {
    background-color: var(--green-900);
    box-shadow: 0 1px 0 var(--line-on-dark);
  }
  #site-header.is-condensed .container {
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }

  /* =========================================================
     Variante fond CLAIR (pages /blog, articles). Le logo passe en
     version foncee (gere cote src), et la navigation doit basculer du
     texte clair au vert profond --ink pour rester lisible sur le creme.
     Le bouton CTA (fond dore) fonctionne sur les deux fonds : inchange.
     ========================================================= */
  #site-header.is-light .nav-link {
    /* Tailwind text-on-dark est surcharge ici. Opacite 0.85 gere en propriete
       distincte : une opacite arbitraire sur une var non-RGB ne se resout pas
       cote couleur, on separe donc color et opacity. */
    color: var(--ink);
    opacity: 0.85;
  }
  #site-header.is-light .nav-link:hover {
    color: var(--gold);
    opacity: 1;
  }
  /* Liens du menu mobile en fond clair (avant ouverture du panneau vert). */
  #site-header.is-light [data-mobile-link] {
    color: var(--ink);
  }
  #site-header.is-light [data-mobile-link]:hover {
    color: var(--gold);
  }
  /* Barres du burger : vert profond sur fond clair. */
  #site-header.is-light .menu-toggle span > span {
    background-color: var(--ink);
  }

  /* En haut de page (etat non condense) sur fond clair : le header laisse
     voir le creme dessous, on garde un filet bas tres fin pour delimiter la
     barre sans l'alourdir. */
  #site-header.is-light {
    box-shadow: 0 1px 0 rgba(22, 36, 28, 0.06);
  }

  /* Sticky au scroll sur fond clair : au lieu du fond vert profond (qui
     renverrait le logo/nav fonces illisibles), on pose un fond creme legerement
     contraste et une fine bordure basse doree. Le logo fonce et les liens --ink
     restent parfaitement lisibles. */
  #site-header.is-light.is-condensed {
    background-color: var(--cream-soft);
    box-shadow: 0 1px 0 var(--line);
  }
  /* Une fois le panneau mobile ouvert, il reprend son fond vert sombre :
     les liens redeviennent clairs a l'interieur pour contraster. */
  #site-header.is-light .mobile-menu[data-open='true'] [data-mobile-link] {
    color: var(--on-dark);
  }
  #site-header.is-light .mobile-menu[data-open='true'] [data-mobile-link]:hover {
    color: var(--gold);
  }

  /* Menu mobile : animation d'ouverture via max-height. On pilote l'etat
     avec l'attribut data-open et non des classes Tailwind arbitraires ajoutees
     en JS : Tailwind ne genere que les classes qu'il voit statiquement dans les
     sources, donc grid-rows-[1fr] ajoutee dynamiquement n'aurait aucune regle
     CSS et le menu resterait ferme. La regle existe toujours dans ce <style>
     scope, l'ouverture est fiable.

     On evite grid-template-rows 0fr vers 1fr : sur un conteneur a hauteur
     indefinie (flux normal, sans hauteur explicite), la fraction 1fr se resout
     a 0px et le menu ne s'ouvre pas. max-height avec une valeur large (80vh,
     couvre tout contenu de menu court) est fiable quel que soit le contexte. */
  .mobile-menu {
    max-height: 0;
    transition: max-height 500ms var(--ease);
  }
  .mobile-menu[data-open='true'] {
    max-height: 80vh;
  }
  /* Au-dela du point de bascule, le menu mobile est masque (la nav
     desktop prend le relais). */
  @media (min-width: 1180px) {
    .mobile-menu {
      display: none;
    }
  }
</style>
