---
/*
  Eyebrow : petit label uppercase. Couleur adaptable via prop tone.
*/
interface Props {
  /** Sur fond sombre, on passe le texte en clair */
  tone?: 'dark' | 'light';
  class?: string;
}
const { tone = 'light', class: className = '' } = Astro.props;
const color = tone === 'dark' ? 'text-on-dark/[0.92]' : 'text-ink-muted';
---

<span class={`type-eyebrow inline-flex items-center ${color} ${className}`}>
  <slot />
</span>
