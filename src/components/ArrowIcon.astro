---
/*
  Fleche diagonale (haut-droite) inline, sans dependance d'icones.
  Utilisee dans le rond des boutons.
*/
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class={className}
  width="16"
  height="16"
  viewBox="0 0 16 16"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <path
    d="M4 12L12 4M12 4H5.5M12 4V10.5"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
